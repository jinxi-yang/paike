<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>鍖楁竻鍟嗗闄?- 鏅鸿兘鎺掕绯荤粺</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap');

        body {
            font-family: 'Inter', 'Microsoft YaHei', sans-serif;
            background-color: #f8fafc;
            color: #1e293b;
        }

        .glass-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            box-shadow: 0 4px 20px -5px rgba(0, 0, 0, 0.05);
        }

        .active-tab {
            border-bottom: 3px solid #2563eb;
            color: #2563eb;
            background: linear-gradient(to top, #eff6ff, transparent);
        }

        .modal-overlay {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(4px);
            display: none;
            position: fixed;
            inset: 0;
            z-index: 9999;
            align-items: center;
            justify-content: center;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal-content {
            transform: scale(0.95);
            opacity: 0;
            transition: all 0.2s ease-out;
        }

        .modal-overlay.active .modal-content {
            transform: scale(1);
            opacity: 1;
        }

        .scroll-hide::-webkit-scrollbar {
            width: 4px;
            height: 4px;
        }

        .scroll-hide::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

        .conflict-badge {
            animation: pulse 2s infinite;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: 0.5;
            }
        }

        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid #e2e8f0;
            border-top-color: #2563eb;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* 鎷栨嫿鏍峰紡 */
        .draggable {
            cursor: grab;
            transition: all 0.2s ease;
        }

        .draggable:active {
            cursor: grabbing;
        }

        .draggable.dragging {
            opacity: 0.5;
            transform: scale(1.02);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        }

        .drop-zone {
            min-height: 60px;
            transition: all 0.2s ease;
        }

        .drop-zone.drag-over {
            background-color: #dbeafe !important;
            border: 2px dashed #3b82f6 !important;
        }
    </style>
</head>

<body class="h-screen flex flex-col overflow-hidden">
    <!-- API 閰嶇疆 -->
    <script>
        const API_BASE = 'http://localhost:5000/api';
    </script>

    <!-- 椤堕儴瀵艰埅鏍?-->
    <header class="h-16 bg-white border-b flex items-center justify-between px-8 z-50 shrink-0">
        <div class="flex items-center gap-4">
            <div
                class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-blue-200">
                <i data-lucide="graduation-cap"></i>
            </div>
            <div>
                <h1 class="text-lg font-bold leading-tight">鍖楁竻鍟嗗闄?<span class="text-blue-600">鏅鸿兘鎺掕</span></h1>
                <p class="text-[10px] text-slate-400 uppercase tracking-widest font-bold">Course Scheduling System</p>
            </div>
        </div>
        <nav class="flex gap-2 h-full">
            <button onclick="switchTab('scheduler')" id="tab-scheduler"
                class="px-6 flex items-center gap-2 active-tab font-semibold transition-all">
                <i data-lucide="calendar-range" class="w-4 h-4"></i> 鏅鸿兘璇剧▼缂栨帓
            </button>
            <button onclick="switchTab('manage')" id="tab-manage"
                class="px-6 flex items-center gap-2 text-slate-500 hover:text-blue-600 font-semibold transition-all">
                <i data-lucide="settings" class="w-4 h-4"></i> 鍩虹鏁版嵁绠＄悊
            </button>
        </nav>
        <div class="flex items-center gap-4">
            <span class="text-sm text-slate-500" id="connection-status">杩炴帴涓?..</span>
        </div>
    </header>

    <main class="flex-1 overflow-hidden p-6 relative">
        <!-- 瑙嗗浘涓€锛氭櫤鑳借绋嬬紪鎺?-->
        <div id="view-scheduler" class="h-full flex flex-col gap-6">
            <!-- 椤堕儴锛氬煿璁彮绫诲瀷鍗＄墖 -->
            <div class="glass-card p-4 overflow-hidden">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="font-bold text-slate-700 text-sm flex items-center gap-2">
                        <i data-lucide="layers" class="w-4 h-4 text-blue-600"></i> 鍩硅鐝被鍨嬶紙鐐瑰嚮杩涘叆鐝骇绠＄悊锛?
                    </h3>
                    <div class="flex items-center gap-3">
                        <span id="training-type-count" class="text-xs text-slate-400"></span>
                    </div>
                </div>
                <div id="training-types-container" class="flex gap-4 overflow-x-auto pb-4 scroll-hide">
                    <div class="flex items-center justify-center p-8 text-slate-400">
                        <span class="loading"></span>
                        <span class="ml-2">鍔犺浇涓?..</span>
                    </div>
                </div>
            </div>

            <!-- 涓嬮儴锛氭帓璇惧伐浣滃尯 -->
            <div class="flex-1 grid grid-cols-12 gap-6 overflow-hidden">
                <!-- 宸︿晶 Prompt Center -->
                <div class="col-span-3 glass-card flex flex-col p-5 overflow-y-auto">
                    <h3 class="font-bold text-slate-700 mb-6 flex items-center gap-2">
                        <i data-lucide="terminal" class="w-4 h-4 text-blue-600"></i> AI 鎺掕鍔╂墜
                    </h3>
                    <div class="space-y-6 flex-1">
                        <section>

                            <section>
                                <label
                                    class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">鎺掕绛栫暐</label>
                                <div class="mt-2 space-y-2">
                                    <label
                                        class="flex items-center justify-between p-2.5 bg-slate-50 rounded-xl border text-xs cursor-pointer hover:bg-slate-100">
                                        <div class="flex flex-col">
                                            <span class="font-bold text-slate-700">鍐茬獊澶勭悊</span>
                                            <span class="text-[10px] text-slate-400">璧勬簮琚崰鐢ㄦ垨璇峰亣鏃?/span>
                                        </div>
                                        <select id="conflict-mode" class="bg-white border text-xs rounded p-1">
                                            <option value="postpone">鑷姩椤哄欢 (鎺ㄨ崘)</option>
                                            <option value="mark">淇濈暀浣嶇疆骞舵爣璁?/option>
                                        </select>
                                    </label>
                                </div>
                            </section>
                            <section class="flex-1 flex flex-col pt-4">
                                <label
                                    class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">瀹氬埗鎻愮ず璇?/label>
                                <textarea id="prompt-input"
                                    class="w-full flex-1 mt-2 border rounded-xl p-3 text-xs focus:ring-2 focus:ring-blue-500 outline-none leading-relaxed min-h-[120px]"
                                    placeholder="渚嬪锛?鏈?5鏃ュ寳浜湁澶у瀷鍖荤枟宄颁細锛屽尰鐤楃彮閭ｅぉ涓嶈兘涓婅銆傜帇鑺宠€佸笀3鏈?1-22鏃ヨ鍋囦簡銆?></textarea>
                            </section>
                            <button onclick="smartGenerateSchedule(event)" id="smart-generate-btn"
                                class="w-full bg-indigo-600 text-white py-3.5 rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-indigo-700 shadow-lg shadow-indigo-100 active:scale-95 transition-all">
                                <i data-lucide="sparkles" class="w-4 h-4"></i> 鏅鸿兘閲嶆柊鐢熸垚璇捐〃
                            </button>
                            <div id="constraints-result"
                                class="hidden bg-blue-50 p-3 rounded-xl border border-blue-200 text-xs space-y-2 mt-4">
                                <div class="font-bold text-blue-700">AI 鎻愬彇鍒扮殑绾︽潫锛?/div>
                                <div id="constraints-content"></div>
                            </div>
                    </div>
                </div>

                <!-- 鍙充晶锛氭湀搴︽帓璇剧湅鏉?-->
                <div class="col-span-9 glass-card flex flex-col overflow-hidden">
                    <div class="p-4 border-b flex justify-between items-center bg-slate-50/50">
                        <div class="flex items-center gap-6">
                            <div class="flex items-center gap-3">
                                <h4 id="month-display" class="font-bold text-slate-800 text-lg">2026骞?鏈?/h4>
                                <div class="flex bg-white border rounded-lg overflow-hidden shadow-sm">
                                    <button onclick="changeMonth(-1)" class="px-2 py-1 hover:bg-slate-50 border-r"><i
                                            data-lucide="chevron-left" class="w-4 h-4"></i></button>
                                    <button onclick="changeMonth(1)" class="px-2 py-1 hover:bg-slate-50"><i
                                            data-lucide="chevron-right" class="w-4 h-4"></i></button>
                                </div>
                            </div>
                            <div id="month-status"
                                class="bg-slate-100 text-slate-600 px-3 py-1 rounded-full text-[10px] font-bold">鑽夌
                            </div>
                            <!-- 瑙嗗浘鍒囨崲 -->
                            <div class="flex bg-slate-100 p-1 rounded-lg">
                                <button onclick="switchViewMode('week')" id="view-mode-week"
                                    class="px-3 py-1 rounded-md text-xs font-bold bg-white text-blue-600 shadow-sm transition-all">鍛ㄨ鍥?/button>
                                <button onclick="switchViewMode('month')" id="view-mode-month"
                                    class="px-3 py-1 rounded-md text-xs font-bold text-slate-500 hover:text-slate-700 transition-all">鏈堣鍥?/button>
                            </div>
                        </div>
                        <div class="flex gap-4 items-center">
                            <div id="merge-controls" class="flex gap-2">
                                <button onclick="toggleMergeMode()" id="merge-mode-btn"
                                    class="px-3 py-1.5 text-xs font-bold bg-purple-100 text-purple-600 rounded-lg hover:bg-purple-200 transition-all flex items-center gap-1">
                                    <i data-lucide="layers" class="w-3 h-3"></i> 鍚堢彮妯″紡
                                </button>
                                <button onclick="executeMerge()" id="confirm-merge-btn"
                                    class="hidden px-3 py-1.5 text-xs font-bold bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-all flex items-center gap-1 shadow-md">
                                    <i data-lucide="check" class="w-3 h-3"></i> 纭鍚堝苟 <span id="merge-count"
                                        class="bg-white/20 px-1.5 rounded text-[9px]">0</span>
                                </button>
                            </div>
                            <div class="h-4 w-px bg-slate-200"></div>
                            <div class="flex items-center gap-1.5 text-[10px] font-semibold text-slate-400"><span
                                    class="w-2.5 h-2.5 bg-red-500 rounded-full"></span> 鍐茬獊</div>
                            <div class="flex items-center gap-1.5 text-[10px] font-semibold text-slate-400"><span
                                    class="w-2.5 h-2.5 bg-green-500 rounded-full"></span> 宸叉帓</div>
                            <div class="flex items-center gap-1.5 text-[10px] font-semibold text-slate-400"><span
                                    class="w-2.5 h-2.5 bg-purple-500 rounded-full"></span> 鍚堢彮</div>
                        </div>
                    </div>
                    <div id="schedule-container" class="flex-1 p-6 overflow-y-auto scroll-hide bg-slate-50/30">
                        <div class="flex items-center justify-center h-full text-slate-400">
                            <span class="loading"></span>
                            <span class="ml-2">鍔犺浇鎺掕鏁版嵁...</span>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- 瑙嗗浘浜岋細鍩虹鏁版嵁绠＄悊锛堢畝鍖栫増锛?-->
        <div id="view-manage" class="hidden h-full grid grid-cols-3 gap-6">
            <!-- 鐝富浠荤鐞?-->
            <div class="glass-card flex flex-col overflow-hidden">
                <div class="p-4 border-b bg-indigo-600 text-white">
                    <h3 class="font-bold">鐝富浠荤鐞?/h3>
                </div>
                <div id="homerooms-list" class="flex-1 p-4 overflow-y-auto space-y-2"></div>
                <div class="p-4 border-t flex gap-2">
                    <input id="new-homeroom-name" placeholder="鐝富浠诲鍚? class="flex-1 text-sm p-2 border rounded-lg">
                    <button onclick="addHomeroom()"
                        class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-bold">娣诲姞</button>
                </div>
            </div>
            <!-- 璁插笀绠＄悊 -->
            <div class="glass-card flex flex-col overflow-hidden">
                <div class="p-4 border-b bg-blue-600 text-white">
                    <h3 class="font-bold">鎺堣璁插笀绠＄悊</h3>
                </div>
                <div id="teachers-list" class="flex-1 p-4 overflow-y-auto space-y-2"></div>
                <div class="p-4 border-t flex gap-2">
                    <input id="new-teacher-name" placeholder="璁插笀濮撳悕" class="flex-1 text-sm p-2 border rounded-lg">
                    <button onclick="addTeacher()"
                        class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-bold">娣诲姞</button>
                </div>
            </div>
            <!-- 璇剧▼绠＄悊 -->
            <div class="glass-card flex flex-col overflow-hidden">
                <div class="p-4 border-b bg-green-600 text-white">
                    <h3 class="font-bold">璇剧▼绠＄悊</h3>
                </div>
                <div class="p-2 border-b bg-slate-50">
                    <select id="course-topic-filter" class="w-full text-xs p-2 border rounded-lg"
                        onchange="filterCoursesByTopic()">
                        <option value="">-- 鍏ㄩ儴璇鹃 --</option>
                    </select>
                </div>
                <div id="courses-list" class="flex-1 p-4 overflow-y-auto space-y-2"></div>
                <div class="p-4 border-t flex flex-col gap-2">
                    <select id="new-course-topic" class="w-full text-xs p-2 border rounded-lg">
                        <option value="">-- 閫夋嫨鎵€灞炶棰?--</option>
                    </select>
                    <div class="flex gap-2">
                        <input id="new-course-name" placeholder="璇剧▼鍚嶇О" class="flex-1 text-sm p-2 border rounded-lg">
                        <button onclick="addCourse()"
                            class="px-4 py-2 bg-green-600 text-white rounded-lg text-sm font-bold">娣诲姞</button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- 鍩硅鐝鎯呭脊绐?-->
    <div id="training-detail-modal" class="modal-overlay" onclick="if(event.target==this) closeTrainingDetail()">
        <div class="modal-content glass-card w-[900px] max-h-[85vh] overflow-hidden flex flex-col">
            <div class="p-6 border-b bg-blue-600 text-white flex justify-between items-center">
                <div>
                    <h3 id="training-detail-title" class="text-xl font-bold">鍩硅鐝鎯?/h3>
                    <p class="text-xs opacity-80 mt-1">绠＄悊鐝骇鍜岃棰橀『搴?/p>
                </div>
                <button onclick="closeTrainingDetail()" class="hover:bg-blue-700 p-2 rounded-full"><i data-lucide="x"
                        class="w-6 h-6"></i></button>
            </div>
            <div class="flex-1 overflow-y-auto p-6 space-y-6">
                <!-- 璇鹃鍒楄〃 -->
                <div>
                    <h4 class="font-bold text-slate-700 mb-3 flex items-center gap-2">
                        <i data-lucide="list-ordered" class="w-4 h-4 text-blue-600"></i> 璇鹃鍒楄〃锛堝叡8鑺傦級
                    </h4>
                    <div id="topics-list" class="space-y-2"></div>
                </div>
                <!-- 鐝骇绠＄悊 -->
                <div class="bg-white p-4 rounded-xl border">
                    <h4 class="font-bold text-slate-700 mb-3">鐝骇绠＄悊</h4>
                    <div id="classes-list" class="space-y-2 mb-4"></div>
                    <button onclick="openAddClassModal()"
                        class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-bold">+ 鏂板鐝骇</button>
                </div>
            </div>
            <div class="p-6 border-t bg-slate-50 flex justify-end">
                <button onclick="closeTrainingDetail()"
                    class="px-6 py-2 rounded-xl border bg-white text-sm font-bold text-slate-500">鍏抽棴</button>
            </div>
        </div>
    </div>

    <!-- 鏂板鐝骇寮圭獥 -->
    <div id="add-class-modal" class="modal-overlay" onclick="if(event.target==this) closeAddClassModal()">
        <div class="modal-content glass-card w-[520px]">
            <div class="p-4 border-b bg-blue-600 text-white flex justify-between items-center">
                <h3 class="font-bold">鏂板鐝骇</h3>
                <button onclick="closeAddClassModal()" class="p-2 rounded-full hover:bg-blue-700"><i data-lucide="x"
                        class="w-5 h-5"></i></button>
            </div>
            <div class="p-4 space-y-4">
                <div>
                    <label class="text-xs font-bold">鐝骇鍚嶇О</label>
                    <input id="new-class-name" class="w-full text-sm p-2 border rounded-lg mt-1"
                        placeholder="渚嬪锛氶琚栧闀挎湰绉戠彮 1鏈?>
                </div>
                <div>
                    <label class="text-xs font-bold">棣栨涓婅鏃ユ湡</label>
                    <input id="new-class-date" type="date" class="w-full text-sm p-2 border rounded-lg mt-1">
                </div>
                <div>
                    <label class="text-xs font-bold">鐝富浠?/label>
                    <select id="new-class-homeroom" class="w-full text-sm p-2 border rounded-lg mt-1">
                        <option value="">-- 閫夋嫨鐝富浠?--</option>
                    </select>
                </div>
                                <div id="class-precheck-panel" class="border rounded-lg bg-slate-50 p-3 hidden">
                    <div class="flex items-center justify-between mb-2">
                        <div class="text-xs font-bold text-slate-700">排班预检</div>
                        <button type="button" onclick="runClassPrecheck()" class="text-[11px] text-blue-600 hover:underline">重新预检</button>
                    </div>
                    <div id="class-precheck-loading" class="hidden text-xs text-slate-500">正在预检，请稍候...</div>
                    <div id="class-precheck-content" class="text-xs text-slate-700"></div>
                </div>
                <p class="text-[10px] text-slate-400">绯荤粺灏嗚嚜鍔ㄦ寜姣?鍛ㄤ竴鑺傝鐨勮鍒欑敓鎴?鑺傝鐨勯鎺掕琛?/p>
            </div>
            <div class="p-4 border-t bg-slate-50 flex justify-end gap-3">
                <button onclick="closeAddClassModal()"
                    class="px-4 py-2 rounded-xl border bg-white text-sm font-bold text-slate-500">鍙栨秷</button>
                <button onclick="createClass()"
                    class="px-4 py-2 rounded-xl bg-blue-600 text-white text-sm font-bold">鍒涘缓骞剁敓鎴愯琛?/button>
            </div>
        </div>
    </div>

    <!-- 鐝骇璇捐〃寮圭獥 -->
    <div id="class-schedule-modal" class="modal-overlay" onclick="if(event.target==this) closeClassSchedule()">
        <div class="modal-content glass-card w-[900px] max-h-[85vh] overflow-hidden flex flex-col">
            <div class="p-4 border-b bg-blue-600 text-white flex justify-between items-center">
                <div>
                    <h3 id="class-schedule-title" class="font-bold">鐝骇璇捐〃</h3>
                    <p class="text-xs opacity-80">鏌ョ湅鍜岃皟鏁寸彮绾ц绋嬪畨鎺?/p>
                </div>
                <button onclick="closeClassSchedule()" class="p-2 rounded-full hover:bg-blue-700"><i data-lucide="x"
                        class="w-5 h-5"></i></button>
            </div>
            <div id="class-schedule-content" class="flex-1 p-4 overflow-y-auto space-y-3"></div>
            <div class="p-4 border-t bg-slate-50 flex justify-end">
                <button onclick="closeClassSchedule()"
                    class="px-6 py-2 rounded-xl border bg-white text-sm font-bold text-slate-500">鍏抽棴</button>
            </div>
        </div>
    </div>

    <!-- 璋冩暣璇剧▼寮圭獥 -->
    <div id="adjust-schedule-modal" class="modal-overlay" onclick="if(event.target==this) closeAdjustModal()">
        <div class="modal-content glass-card w-[500px]">
            <div class="p-4 border-b bg-indigo-600 text-white flex justify-between items-center">
                <h3 class="font-bold">璋冩暣璇剧▼</h3>
                <button onclick="closeAdjustModal()" class="p-2 rounded-full hover:bg-indigo-700"><i data-lucide="x"
                        class="w-5 h-5"></i></button>
            </div>
            <div class="p-4 space-y-4">
                <div id="adjust-schedule-info" class="p-3 bg-slate-50 rounded-lg text-sm"></div>
                <div>
                    <label class="text-xs font-bold">璋冩暣鏃ユ湡</label>
                    <input id="adjust-new-date" type="date" class="w-full text-sm p-2 border rounded-lg mt-1">
                </div>
                <div>
                    <label class="text-xs font-bold">閫夋嫨鏁?璇剧粍鍚?/label>
                    <select id="adjust-combo" class="w-full text-sm p-2 border rounded-lg mt-1">
                        <option value="">-- 閫夋嫨缁勫悎 --</option>
                    </select>
                </div>
                <div class="flex gap-2">
                    <button onclick="moveScheduleWeek('prev')"
                        class="flex-1 px-4 py-2 bg-slate-100 rounded-lg text-sm font-bold hover:bg-slate-200">鈫?
                        涓婁竴鍛?/button>
                    <button onclick="moveScheduleWeek('next')"
                        class="flex-1 px-4 py-2 bg-slate-100 rounded-lg text-sm font-bold hover:bg-slate-200">涓嬩竴鍛?
                        鈫?/button>
                </div>
            </div>
            <div class="p-4 border-t bg-slate-50 flex justify-end gap-3">
                <button onclick="closeAdjustModal()"
                    class="px-4 py-2 rounded-xl border bg-white text-sm font-bold text-slate-500">鍙栨秷</button>
                <button onclick="saveAdjustment()"
                    class="px-4 py-2 rounded-xl bg-indigo-600 text-white text-sm font-bold">淇濆瓨璋冩暣</button>
            </div>
        </div>
    </div>

    <!-- 鏂板鏁?璇剧粍鍚堝脊绐?-->
    <div id="add-combo-modal" class="modal-overlay" onclick="if(event.target==this) closeAddComboModal()">
        <div class="modal-content glass-card w-[500px]">
            <div class="p-4 border-b bg-green-600 text-white flex justify-between items-center">
                <h3 class="font-bold">閰嶇疆鏁?璇剧粍鍚?/h3>
                <button onclick="closeAddComboModal()" class="p-2 rounded-full hover:bg-green-700"><i data-lucide="x"
                        class="w-5 h-5"></i></button>
            </div>
            <div class="p-4 space-y-4">
                <input type="hidden" id="new-combo-topic-id">
                <div>
                    <label class="text-xs font-bold">閫夋嫨璁插笀</label>
                    <select id="new-combo-teacher" class="w-full text-sm p-2 border rounded-lg mt-1">
                        <option value="">-- 閫夋嫨璁插笀 --</option>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-bold">閫夋嫨璇剧▼</label>
                    <select id="new-combo-course" class="w-full text-sm p-2 border rounded-lg mt-1">
                        <option value="">-- 閫夋嫨璇剧▼ --</option>
                    </select>
                </div>
            </div>
            <div class="p-4 border-t bg-slate-50 flex justify-end gap-3">
                <button onclick="closeAddComboModal()"
                    class="px-4 py-2 rounded-xl border bg-white text-sm font-bold text-slate-500">鍙栨秷</button>
                <button onclick="createCombo()"
                    class="px-4 py-2 rounded-xl bg-green-600 text-white text-sm font-bold">淇濆瓨閰嶇疆</button>
            </div>
        </div>
    </div>

    <!-- 鍙戝竷棰勮寮圭獥 -->
    <div id="publish-preview-modal" class="modal-overlay" onclick="if(event.target==this) closePublishPreview()">
        <div class="modal-content glass-card w-[980px] max-h-[85vh] overflow-hidden flex flex-col">
            <div class="p-4 border-b bg-green-600 text-white flex justify-between items-center">
                <div>
                    <h3 class="font-bold">鍙戝竷鍓嶉瑙?/h3>
                    <p class="text-xs opacity-80 mt-1">鎸夊懆鍏?鍛ㄦ棩鏃ュ巻鏍煎紡棰勮鏈湀鎺掕</p>
                </div>
                <button onclick="closePublishPreview()" class="p-2 rounded-full hover:bg-green-700"><i data-lucide="x"
                        class="w-5 h-5"></i></button>
            </div>
            <div id="publish-preview-content" class="flex-1 p-4 overflow-y-auto bg-slate-50"></div>
            <div class="p-4 border-t bg-white flex items-end justify-between gap-3">
                <div id="publish-force-controls" class="hidden flex-1">
                    <label class="flex items-center gap-2 text-xs text-slate-700 mb-2">
                        <input type="checkbox" id="force-publish-all" class="rounded border-slate-300">
                        鍏佽寮哄埗鍙戝竷鎵€鏈夋棤娉曡В鍐冲啿绐?
                    </label>
                    <textarea id="force-publish-note" class="w-full border rounded-lg p-2 text-xs" rows="2"
                        placeholder="寮哄埗鍙戝竷澶囨敞锛堝繀濉級"></textarea>
                    <div id="publish-block-tip" class="text-[11px] text-red-600 mt-1 hidden"></div>
                </div>
                <button onclick="closePublishPreview()"
                    class="px-4 py-2 rounded-xl border bg-white text-sm font-bold text-slate-500">鍙栨秷</button>
                <button id="publish-confirm-btn" onclick="executePublishMonth()"
                    class="px-4 py-2 rounded-xl bg-green-600 text-white text-sm font-bold">纭鍙戝竷</button>
            </div>
        </div>
    </div>

    <script>
        // ==================== 鍏ㄥ眬鐘舵€?====================
        let currentYear = 2026;
        let currentMonth = 3;
        let currentTrainingTypeId = null;
        let currentClassId = null;
        let currentScheduleId = null;
        // 鍚堢彮妯″紡鐘舵€?
        let isMergeMode = false;
        let selectedMergeIds = new Set();
        let publishChecklistState = { unresolved: [], pending: [], resolved: [] };
        let classPrecheckState = null;

        // ==================== 鍒濆鍖?====================
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            checkConnection();
            loadTrainingTypes();
            loadMonthSchedule();
            initClassPrecheckEvents();
        });

        async function checkConnection() {
            try {
                const resp = await fetch(`${API_BASE}/health`);
                if (resp.ok) {
                    document.getElementById('connection-status').innerHTML = '<span class="text-green-600">鈼?宸茶繛鎺?/span>';
                } else {
                    document.getElementById('connection-status').innerHTML = '<span class="text-red-600">鈼?杩炴帴澶辫触</span>';
                }
            } catch (e) {
                document.getElementById('connection-status').innerHTML = '<span class="text-red-600">鈼?鍚庣鏈惎鍔?/span>';
            }
        }

        // ==================== 瑙嗗浘鍒囨崲 ====================
        function switchTab(tab) {
            document.querySelectorAll('main > div').forEach(d => d.classList.add('hidden'));
            document.getElementById(`view-${tab}`).classList.remove('hidden');
            document.querySelectorAll('nav button').forEach(b => { b.classList.remove('active-tab', 'text-blue-600'); b.classList.add('text-slate-500'); });
            const btn = document.getElementById(`tab-${tab}`);
            btn.classList.add('active-tab', 'text-blue-600');
            btn.classList.remove('text-slate-500');
            lucide.createIcons();

            if (tab === 'manage') {
                loadHomerooms();
                loadTeachers();
                loadCourses();
            }
        }

        // ==================== 鍩硅鐝被鍨?====================
        async function loadTrainingTypes() {
            try {
                const resp = await fetch(`${API_BASE}/training-types`);
                const types = await resp.json();
                renderTrainingTypes(types);
                document.getElementById('training-type-count').textContent = `鍏?${types.length} 绉嶅煿璁彮`;
            } catch (e) {
                document.getElementById('training-types-container').innerHTML = '<div class="text-red-500 p-4">鍔犺浇澶辫触锛岃妫€鏌ュ悗绔湇鍔?/div>';
            }
        }

        function renderTrainingTypes(types) {
            const container = document.getElementById('training-types-container');
            container.innerHTML = types.map((t, i) => `
                <div onclick="openTrainingDetail(${t.id})" class="project-card min-w-[260px] ${i === 0 ? 'bg-white border-2 border-blue-500' : 'bg-slate-50 border border-slate-200'} rounded-xl p-4 cursor-pointer shadow-md transition-all hover:border-blue-700 hover:shadow-lg">
                    <div class="flex justify-between items-start mb-3">
                        <span class="text-[11px] font-bold text-blue-600 uppercase">${t.name}</span>
                    </div>
                    <p class="text-[10px] text-slate-500 mb-2">${t.description || ''}</p>
                    <div class="flex justify-between text-[9px] text-slate-400">
                        <span>8涓棰?/span>
                        <span class="text-blue-600 font-bold">鐐瑰嚮绠＄悊 鈫?/span>
                    </div>
                </div>
            `).join('');
        }

        // ==================== 鍩硅鐝鎯?====================
        async function openTrainingDetail(id) {
            currentTrainingTypeId = id;
            try {
                const resp = await fetch(`${API_BASE}/training-types/${id}`);
                const data = await resp.json();
                document.getElementById('training-detail-title').textContent = data.name;
                renderTopics(data.topics || []);
                await loadClasses(id);
                document.getElementById('training-detail-modal').classList.add('active');
                lucide.createIcons();
            } catch (e) {
                alert('鍔犺浇澶辫触');
            }
        }

        function closeTrainingDetail() {
            document.getElementById('training-detail-modal').classList.remove('active');
        }

        function renderTopics(topics) {
            const container = document.getElementById('topics-list');
            container.innerHTML = topics.map(t => `
                <div class="bg-white border rounded-lg p-4 transition-all hover:shadow-md">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-3">
                            <span class="w-8 h-8 rounded-full ${t.is_fixed ? 'bg-blue-600' : 'bg-slate-400'} text-white flex items-center justify-center text-sm font-bold">${t.sequence}</span>
                            <div>
                                <div class="font-bold text-slate-700">${t.name}</div>
                                ${t.is_fixed ? '<span class="text-[10px] text-blue-600 font-bold bg-blue-50 px-2 py-0.5 rounded">鍥哄畾璇鹃</span>' : ''}
                            </div>
                        </div>
                        <button onclick="openAddComboModal(${t.id})" class="text-xs bg-slate-100 hover:bg-slate-200 text-slate-600 px-3 py-1.5 rounded-lg font-bold transition-all flex items-center gap-1">
                            <i data-lucide="plus" class="w-3 h-3"></i> 閰嶇疆鏁?璇?
                        </button>
                    </div>
                    
                    <!-- 鏁?璇剧粍鍚堝垪琛?-->
                    <div class="space-y-2 pl-11">
                        ${(t.combos || []).length > 0 ? (t.combos || []).map(c => `
                            <div class="flex items-center justify-between p-2.5 bg-slate-50 border border-slate-100 rounded-lg text-sm hover:border-blue-200 transition-all group">
                                <div class="flex items-center gap-3">
                                    <span class="font-semibold text-slate-700">${c.teacher_name}</span>
                                    <span class="text-slate-300">|</span>
                                    <span class="text-slate-600">${c.course_name}</span>
                                </div>
                                <button onclick="deleteCombo(${c.id})" class="text-slate-400 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-all p-1">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        `).join('') : '<div class="text-[10px] text-slate-400 italic">鏆傛棤鏁?璇剧粍鍚堥厤缃?/div>'}
                    </div>
                </div>
            `).join('');
            lucide.createIcons();
        }

        async function loadClasses(trainingTypeId) {
            try {
                const resp = await fetch(`${API_BASE}/classes?training_type_id=${trainingTypeId}`);
                const classes = await resp.json();
                renderClasses(classes);
            } catch (e) {
                console.error('鍔犺浇鐝骇澶辫触', e);
            }
        }

        function renderClasses(classes) {
            const container = document.getElementById('classes-list');
            if (classes.length === 0) {
                container.innerHTML = '<div class="text-slate-400 text-sm p-3">鏆傛棤鐝骇锛岃鐐瑰嚮涓嬫柟鎸夐挳鏂板</div>';
                return;
            }
            container.innerHTML = classes.map(c => `
                <div class="flex items-center justify-between p-3 bg-slate-50 border rounded-lg">
                    <div>
                        <div class="font-medium text-sm">${c.name}</div>
                        <div class="text-[10px] text-slate-500">班主任: ${c.homeroom_name || '未分配'} | 开始: ${c.start_date || '未设置'}</div>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="openClassScheduleModal(${c.id})" class="text-blue-600 text-xs font-bold hover:underline">鏌ョ湅璇捐〃</button>
                        <button onclick="deleteClass(${c.id})" class="text-red-500 text-xs hover:underline">鍒犻櫎</button>
                    </div>
                </div>
            `).join('');
        }

        // ==================== 鏂板鐝骇 ====================
        async function openAddClassModal() {
            // 鍔犺浇鐝富浠诲垪琛?
            try {
                const resp = await fetch(`${API_BASE}/homerooms`);
                const homerooms = await resp.json();
                const select = document.getElementById('new-class-homeroom');
                select.innerHTML = '<option value="">-- 閫夋嫨鐝富浠?--</option>' +
                    homerooms.map(h => `<option value="${h.id}">${h.name}</option>`).join('');
            } catch (e) { }

            // 璁剧疆榛樿鏃ユ湡涓轰笅鍛ㄥ叚
            const today = new Date();
            const daysUntilSat = (6 - today.getDay() + 7) % 7 || 7;
            const nextSat = new Date(today.getTime() + daysUntilSat * 24 * 60 * 60 * 1000);
            document.getElementById('new-class-date').value = nextSat.toISOString().slice(0, 10);

            document.getElementById('add-class-modal').classList.add('active');
            classPrecheckState = null;
            await runClassPrecheck();
            lucide.createIcons();
        }

        function closeAddClassModal() {
            document.getElementById('add-class-modal').classList.remove('active');
        }
        function initClassPrecheckEvents() {
            const dateInput = document.getElementById('new-class-date');
            const homeroomSelect = document.getElementById('new-class-homeroom');
            if (dateInput && !dateInput.dataset.precheckBound) {
                dateInput.addEventListener('change', runClassPrecheck);
                dateInput.dataset.precheckBound = '1';
            }
            if (homeroomSelect && !homeroomSelect.dataset.precheckBound) {
                homeroomSelect.addEventListener('change', () => {
                    if (classPrecheckState) {
                        renderClassPrecheck(classPrecheckState);
                    }
                });
                homeroomSelect.dataset.precheckBound = '1';
            }
        }

        function getRecommendationByHomeroom(homeroomId) {
            if (!classPrecheckState || !Array.isArray(classPrecheckState.homeroom_recommendations)) return null;
            return classPrecheckState.homeroom_recommendations.find(r => String(r.homeroom_id) === String(homeroomId)) || null;
        }

        async function runClassPrecheck() {
            const panel = document.getElementById('class-precheck-panel');
            const loading = document.getElementById('class-precheck-loading');
            const content = document.getElementById('class-precheck-content');
            const startDate = document.getElementById('new-class-date').value;

            if (!panel || !loading || !content) return;
            if (!currentTrainingTypeId || !startDate) {
                panel.classList.add('hidden');
                content.innerHTML = '';
                classPrecheckState = null;
                return;
            }

            panel.classList.remove('hidden');
            loading.classList.remove('hidden');
            content.innerHTML = '';

            try {
                const resp = await fetch(`${API_BASE}/classes/precheck-plan`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        training_type_id: currentTrainingTypeId,
                        start_date: startDate,
                        horizon_weeks: 20
                    })
                });
                const result = await resp.json();
                if (!resp.ok) {
                    throw new Error(result.error || '预检失败');
                }

                classPrecheckState = result;
                renderClassPrecheck(result);
            } catch (e) {
                classPrecheckState = null;
                content.innerHTML = `<div class="text-red-600">预检失败：${escapeHtml(e.message || '未知错误')}</div>`;
            } finally {
                loading.classList.add('hidden');
            }
        }

        function renderClassPrecheck(data) {
            const content = document.getElementById('class-precheck-content');
            const selectedHomeroom = document.getElementById('new-class-homeroom').value;
            if (!content || !data) return;

            const predictedDates = (data.predicted_dates || []).slice(0, 6);
            const restCount = Math.max(0, (data.predicted_dates || []).length - predictedDates.length);
            const predictedText = predictedDates.length
                ? predictedDates.join('、') + (restCount > 0 ? ` 等 ${data.predicted_dates.length} 次周末课` : '')
                : '暂无可预演日期';

            const riskHtml = (data.risk_hints || []).length
                ? `<div class="mt-2 rounded border border-amber-200 bg-amber-50 p-2 text-[11px] text-amber-800">${(data.risk_hints || []).map(item => `<div>• ${escapeHtml(item)}</div>`).join('')}</div>`
                : '';

            const recommendationHtml = (data.homeroom_recommendations || []).slice(0, 4).map(r => {
                const isSelected = String(selectedHomeroom) === String(r.homeroom_id);
                const conflicts = (r.conflicts || []).slice(0, 2).map(c => c.date).join('、');
                const conflictText = r.conflict_count > 0
                    ? `冲突 ${r.conflict_count} 次${conflicts ? `（如 ${conflicts}）` : ''}`
                    : '无冲突';
                return `
                    <div class="rounded border ${isSelected ? 'border-blue-400 bg-blue-50' : 'border-slate-200 bg-white'} p-2 mt-2">
                        <div class="flex items-center justify-between gap-2">
                            <div>
                                <div class="font-semibold">${escapeHtml(r.homeroom_name || '未命名')}</div>
                                <div class="text-[11px] text-slate-600">评分 ${r.score} · ${escapeHtml(conflictText)}</div>
                            </div>
                            <button type="button" onclick="useSuggestedHomeroom(${r.homeroom_id})" class="text-[11px] px-2 py-1 rounded border bg-white hover:bg-slate-50">使用</button>
                        </div>
                    </div>
                `;
            }).join('');

            const selectedConflict = selectedHomeroom ? getRecommendationByHomeroom(selectedHomeroom) : null;
            const selectedWarning = selectedConflict && selectedConflict.conflict_count > 0
                ? `<div class="mt-2 rounded border border-red-200 bg-red-50 p-2 text-[11px] text-red-700">当前班主任存在潜在撞课：${selectedConflict.conflict_count} 次。建议改选推荐班主任或调整开班日期。</div>`
                : '';

            content.innerHTML = `
                <div class="text-[11px] text-slate-600">预演课次：${escapeHtml(predictedText)}</div>
                ${riskHtml}
                <div class="mt-2 text-[11px] font-semibold text-slate-700">班主任建议（按冲突从低到高）</div>
                ${recommendationHtml || '<div class="text-[11px] text-slate-500 mt-2">暂无可用班主任建议</div>'}
                ${selectedWarning}
            `;
        }

        function useSuggestedHomeroom(homeroomId) {
            const select = document.getElementById('new-class-homeroom');
            if (!select) return;
            select.value = String(homeroomId);
            if (classPrecheckState) {
                renderClassPrecheck(classPrecheckState);
            }
        }

        async function createClass() {
            const name = document.getElementById('new-class-name').value.trim();
            const startDate = document.getElementById('new-class-date').value;
            const homeroomId = document.getElementById('new-class-homeroom').value;

            if (!name || !startDate) {
                alert('请填写班级名称和开始日期');
                return;
            }
            if (homeroomId && classPrecheckState) {
                const selected = getRecommendationByHomeroom(homeroomId);
                if (selected && selected.conflict_count > 0) {
                    const sampleDates = (selected.conflicts || []).slice(0, 3).map(c => c.date).join('、');
                    const message = sampleDates
                        ? `该班主任预检存在 ${selected.conflict_count} 次潜在撞课（如 ${sampleDates}）。是否继续创建？`
                        : `该班主任预检存在 ${selected.conflict_count} 次潜在撞课。是否继续创建？`;
                    if (!confirm(message)) {
                        return;
                    }
                }
            }

            try {
                const resp = await fetch(`${API_BASE}/classes`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        training_type_id: currentTrainingTypeId,
                        name,
                        start_date: startDate,
                        homeroom_id: homeroomId ? parseInt(homeroomId) : null,
                        auto_generate: true
                    })
                });

                if (resp.ok) {
                    alert('鐝骇鍒涘缓鎴愬姛');
                    closeAddClassModal();
                    await loadClasses(currentTrainingTypeId);
                    loadMonthSchedule();
                } else {
                    const err = await resp.json();
                    alert('鍒涘缓澶辫触: ' + (err.error || '鏈煡閿欒'));
                }
            } catch (e) {
                alert('鍒涘缓澶辫触: ' + e.message);
            }
        }

        async function deleteClass(id) {
            if (!confirm('确定删除该班级及其课表吗？')) return;
            try {
                await fetch(`${API_BASE}/classes/${id}`, { method: 'DELETE' });
                await loadClasses(currentTrainingTypeId);
                loadMonthSchedule();
            } catch (e) {
                alert('删除失败');
            }
        }

        // ==================== 鏁?璇剧粍鍚堢鐞?====================
        async function openAddComboModal(topicId) {
            document.getElementById('new-combo-topic-id').value = topicId;

            // 鍔犺浇璁插笀鍜岃绋?
            try {
                // 鍔犺浇涓?
                const [teachersResp, coursesResp] = await Promise.all([
                    fetch(`${API_BASE}/teachers`),
                    fetch(`${API_BASE}/courses`)
                ]);

                if (!teachersResp.ok) throw new Error(`璁插笀鏁版嵁鍔犺浇澶辫触: ${teachersResp.status}`);
                if (!coursesResp.ok) throw new Error(`璇剧▼鏁版嵁鍔犺浇澶辫触: ${coursesResp.status}`);

                const teachers = await teachersResp.json();
                const courses = await coursesResp.json();


                if (teachers.length === 0) console.warn('璀﹀憡锛氱郴缁熶腑鏆傛棤璁插笀鏁版嵁');
                if (courses.length === 0) console.warn('璀﹀憡锛氱郴缁熶腑鏆傛棤璇剧▼鏁版嵁');

                document.getElementById('new-combo-teacher').innerHTML = '<option value="">-- 选择讲师 --</option>' +
                    teachers.map(t => `<option value="${t.id}">${t.name} (${t.expertise || '暂无'})</option>`).join('');

                // 杩囨护璇剧▼锛氬彧鏄剧ず灞炰簬褰撳墠璇鹃鐨勮绋嬶紝鎴栬€呮湭鍒嗙被鐨勮绋?
                const currentTopicId = parseInt(topicId);
                const filteredCourses = courses.filter(c => !c.topic_id || c.topic_id === currentTopicId);

                if (filteredCourses.length === 0) {
                    document.getElementById('new-combo-course').innerHTML = '<option value="">-- 璇ヨ棰樻殏鏃犱笓灞炶绋?--</option>';
                } else {
                    document.getElementById('new-combo-course').innerHTML = '<option value="">-- 閫夋嫨璇剧▼ --</option>' +
                        filteredCourses.map(c => `
                            <option value="${c.id}" ${c.topic_id === currentTopicId ? 'class="font-bold bg-blue-50"' : ''}>
                                ${c.topic_id === currentTopicId ? '鈽?' : ''}${c.name}
                            </option>
                        `).join('');
                }

                document.getElementById('add-combo-modal').classList.add('active');
            } catch (e) {
                console.error('鍔犺浇鏁?璇剧粍鍚堟暟鎹け璐?', e);
                alert('鏁版嵁鍔犺浇澶辫触: ' + e.message);
            }
        }

        function closeAddComboModal() {
            document.getElementById('add-combo-modal').classList.remove('active');
        }

        async function createCombo() {
            const topicId = document.getElementById('new-combo-topic-id').value;
            const teacherId = document.getElementById('new-combo-teacher').value;
            const courseId = document.getElementById('new-combo-course').value;

            if (!teacherId || !courseId) {
                alert('请选择讲师和课程');
                return;
            }

            try {
                const resp = await fetch(`${API_BASE}/combos`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        topic_id: topicId,
                        teacher_id: teacherId,
                        course_id: courseId
                    })
                });

                if (resp.ok) {
                    closeAddComboModal();
                    // 閲嶆柊鍔犺浇鍩硅鐝鎯呬互鍒锋柊鍒楄〃
                    openTrainingDetail(currentTrainingTypeId);
                } else {
                    alert('淇濆瓨澶辫触');
                }
            } catch (e) {
                alert('淇濆瓨閿欒: ' + e.message);
            }
        }

        async function deleteCombo(id) {
            if (!confirm('确定删除该教课组合吗？')) return;
            try {
                await fetch(`${API_BASE}/combos/${id}`, { method: 'DELETE' });
                openTrainingDetail(currentTrainingTypeId);
            } catch (e) {
                alert('删除失败');
            }
        }

        // ==================== 鐝骇璇捐〃 ====================
        async function openClassScheduleModal(classId) {
            currentClassId = classId;
            try {
                const resp = await fetch(`${API_BASE}/classes/${classId}`);
                const data = await resp.json();
                document.getElementById('class-schedule-title').textContent = `${data.name} 璇捐〃`;
                renderClassSchedule(data.schedules || []);
                document.getElementById('class-schedule-modal').classList.add('active');
                lucide.createIcons();
            } catch (e) {
                alert('鍔犺浇璇捐〃澶辫触');
            }
        }

        function closeClassSchedule() {
            document.getElementById('class-schedule-modal').classList.remove('active');
        }

        function renderClassSchedule(schedules) {
            const container = document.getElementById('class-schedule-content');
            if (!schedules || schedules.length === 0) {
                container.innerHTML = '<div class="text-slate-400 text-center p-8">鏆傛棤璇剧▼瀹夋帓</div>';
                return;
            }

            // 鎸夊懆鍒嗙粍
            const weeks = {};
            schedules.forEach((s, idx) => {
                const d = new Date(s.scheduled_date);
                const weekStart = new Date(d);
                weekStart.setDate(d.getDate() - d.getDay());
                const weekKey = weekStart.toISOString().slice(0, 10);
                if (!weeks[weekKey]) weeks[weekKey] = [];
                weeks[weekKey].push({ ...s, _idx: idx });
            });

            const sortedWeeks = Object.keys(weeks).sort();

            container.innerHTML = sortedWeeks.map((weekKey, i) => {
                const weekStart = new Date(weekKey);
                const weekEnd = new Date(weekStart);
                weekEnd.setDate(weekEnd.getDate() + 6);

                return `
                    <div class="bg-slate-50 border rounded-xl p-4 mb-4">
                        <h4 class="font-bold text-sm text-slate-700 mb-3">绗?${i + 1} 鍛?路 ${weekStart.toLocaleDateString()} - ${weekEnd.toLocaleDateString()}</h4>
                        <div class="space-y-2 drop-zone" data-week="${weekKey}">
                            ${weeks[weekKey].map(s => {
                    const isPlanning = s.status === 'planning';
                    const isCompleted = s.status === 'completed' || s.status === 'confirmed';
                    const isPast = new Date(s.scheduled_date) < new Date(new Date().setHours(0, 0, 0, 0));

                    let borderClass = isCompleted ? 'border-green-200' : (isPlanning ? 'border-slate-300 border-dashed opacity-80' : 'border-blue-200');
                    let bgClass = isCompleted ? 'bg-green-100 text-green-600' : (isPlanning ? 'bg-slate-100 text-slate-500' : 'bg-blue-100 text-blue-600');

                    return `
                                <div class="draggable p-3 bg-white border ${borderClass} rounded-lg hover:shadow-md transition-all relative group"
                                     draggable="${!isPast}" data-schedule-id="${s.id}" data-week="${weekKey}">
                                    ${isPlanning ? '<div class="absolute top-2 right-2 text-[10px] text-slate-400 bg-slate-100 px-1 rounded border border-slate-200">棰勬帓</div>' : ''}
                                    <div class="flex items-start justify-between">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full ${bgClass} flex items-center justify-center font-bold text-sm">${s.topic_sequence || s.week_number}</div>
                                            <div>
                                                <div class="font-medium text-sm ${isPlanning ? 'text-slate-600' : ''} ${isPast ? 'text-slate-500' : ''}">${s.topic_name}</div>
                                                <div class="text-[10px] text-slate-500">${s.scheduled_date}</div>
                                            </div>
                                        </div>
                                        <div class="text-right">
                                            ${s.combo ? `<div class="text-xs ${isPlanning ? 'text-slate-500' : 'text-blue-600'} font-semibold">${s.combo.teacher_name}</div><div class="text-[10px] text-slate-500">${s.combo.course_name}</div>` : '<div class="text-[10px] text-orange-500">寰呭垎閰?/div>'}
                                        </div>
                                    </div>
                                    <div class="mt-2 flex gap-2 pt-2 border-t border-slate-100 opacity-0 group-hover:opacity-100 transition-opacity">
                                        ${!isPast ? `
                                            <button onclick="openAdjustModal(${s.id})" class="text-[10px] px-2 py-0.5 bg-indigo-100 text-indigo-600 rounded hover:bg-indigo-200">缂栬緫</button>
                                            <button onclick="deleteScheduleItem(${s.id})" class="text-[10px] px-2 py-0.5 bg-red-100 text-red-600 rounded hover:bg-red-200">鍒犻櫎</button>
                                        ` : '<span class="text-[10px] text-slate-400 italic">宸茬粨鏉熻绋嬩笉鍙紪杈?/span>'}
                                    </div>
                                </div>
                            `}).join('')}
                        </div>
                    </div>
                `;
            }).join('');

            // 鍒濆鍖栨嫋鎷戒簨浠?
            initDragAndDrop();
        }

        // 鎷栨嫿鍔熻兘
        function initDragAndDrop() {
            let draggedElement = null;

            document.querySelectorAll('.draggable').forEach(item => {
                item.addEventListener('dragstart', (e) => {
                    draggedElement = item;
                    item.classList.add('dragging');
                    e.dataTransfer.effectAllowed = 'move';
                });

                item.addEventListener('dragend', () => {
                    item.classList.remove('dragging');
                    draggedElement = null;
                    document.querySelectorAll('.drop-zone').forEach(z => z.classList.remove('drag-over'));
                });
            });

            document.querySelectorAll('.drop-zone').forEach(zone => {
                zone.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    e.dataTransfer.dropEffect = 'move';
                    zone.classList.add('drag-over');
                });

                zone.addEventListener('dragleave', () => {
                    zone.classList.remove('drag-over');
                });

                zone.addEventListener('drop', async (e) => {
                    e.preventDefault();
                    zone.classList.remove('drag-over');

                    if (!draggedElement) return;

                    const scheduleId = parseInt(draggedElement.dataset.scheduleId);
                    const sourceWeek = draggedElement.dataset.week;
                    const targetWeek = zone.dataset.week;

                    if (sourceWeek !== targetWeek) {
                        // 绉诲姩鍒扮洰鏍囧懆鐨勫懆鍏?
                        const targetStart = new Date(targetWeek);
                        targetStart.setDate(targetStart.getDate() + (6 - targetStart.getDay()));
                        const newDate = targetStart.toISOString().slice(0, 10);

                        try {
                            const resp = await fetch(`${API_BASE}/schedule/adjust`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ schedule_id: scheduleId, new_date: newDate })
                            });
                            const result = await resp.json();

                            if (result.warning) {
                                if (!confirm(result.warning + '\\n是否继续？')) return;
                                // 寮哄埗鎵ц
                                await fetch(`${API_BASE}/schedule/adjust`, {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ schedule_id: scheduleId, new_date: newDate, force: true })
                                });
                            } else if (result.error) {
                                alert(result.error);
                                return;
                            }

                            // 鍒锋柊璇捐〃
                            openClassScheduleModal(currentClassId);
                            loadMonthSchedule();
                        } catch (err) {
                            alert('绉诲姩澶辫触: ' + err.message);
                        }
                    }
                });
            });
        }

        async function deleteScheduleItem(id) {
            if (!confirm('确定删除此课程吗？')) return;
            try {
                await fetch(`${API_BASE}/schedule/${id}`, { method: 'DELETE' });
                openClassScheduleModal(currentClassId);
                loadMonthSchedule();
            } catch (e) {
                alert('删除失败');
            }
        }

        // ==================== 瑙嗗浘鐘舵€佺鐞?====================
        let cachedMonthData = null;
        let currentWeekIndex = 0;
        let currentViewMode = 'week'; // 'week' | 'month'

        async function loadMonthSchedule() {
            try {
                const resp = await fetch(`${API_BASE}/schedule/month/${currentYear}/${currentMonth}`);
                if (!resp.ok) throw new Error('Failed to load');
                cachedMonthData = await resp.json();

                // 榛樿鏄剧ず绗竴鍛紝鎴栦繚鎸佸綋鍓峣ndex锛堝鏋滆繕鍦ㄨ寖鍥村唴锛?
                if (currentWeekIndex >= (cachedMonthData.weeks || []).length) {
                    currentWeekIndex = 0;
                }

                renderSchedule();
                updateMonthHeader();
            } catch (e) {
                document.getElementById('schedule-container').innerHTML = '<div class="text-center text-slate-400 p-8">鍔犺浇澶辫触锛岃妫€鏌ュ悗绔湇鍔?/div>';
            }
        }

        function switchViewMode(mode) {
            currentViewMode = mode;
            // Update UI buttons
            const btnWeek = document.getElementById('view-mode-week');
            const btnMonth = document.getElementById('view-mode-month');

            if (mode === 'week') {
                btnWeek.className = 'px-3 py-1 rounded-md text-xs font-bold bg-white text-blue-600 shadow-sm transition-all';
                btnMonth.className = 'px-3 py-1 rounded-md text-xs font-bold text-slate-500 hover:text-slate-700 transition-all';
            } else {
                btnWeek.className = 'px-3 py-1 rounded-md text-xs font-bold text-slate-500 hover:text-slate-700 transition-all';
                btnMonth.className = 'px-3 py-1 rounded-md text-xs font-bold bg-white text-blue-600 shadow-sm transition-all';
            }
            renderSchedule();
        }

        function renderSchedule() {
            if (currentViewMode === 'week') {
                renderWeekView();
            } else {
                renderMonthView();
            }
        }

        function updateMonthHeader() {
            if (!cachedMonthData) return;
            document.getElementById('month-display').textContent = `${cachedMonthData.year}年${cachedMonthData.month}月`;
            const statusBadge = document.getElementById('month-status');
            statusBadge.textContent = cachedMonthData.plan_status === 'published' ? '已发布' : '草稿';
            statusBadge.className = cachedMonthData.plan_status === 'published' ?
                'bg-green-100 text-green-600 px-3 py-1 rounded-full text-[10px] font-bold' :
                'bg-slate-100 text-slate-600 px-3 py-1 rounded-full text-[10px] font-bold';
        }

        function changeWeek(delta) {
            if (!cachedMonthData || !cachedMonthData.weeks) return;
            const newIndex = currentWeekIndex + delta;
            if (newIndex >= 0 && newIndex < cachedMonthData.weeks.length) {
                currentWeekIndex = newIndex;
                renderWeekView(); // Ensure this only updates view if in week mode, but generally safe
            }
        }

        function changeMonth(delta) {
            currentMonth += delta;
            if (currentMonth > 12) { currentMonth = 1; currentYear++; }
            if (currentMonth < 1) { currentMonth = 12; currentYear--; }
            currentWeekIndex = 0; // 鍒囨崲鏈堜唤鏃堕噸缃懆绱㈠紩
            loadMonthSchedule();
        }



        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function getConflictSuggestion(reason) {
            const text = (reason || '').toLowerCase();
            if (text.includes('节假日')) return '建议顺延到下一个可用周末';
            if (text.includes('请假') || text.includes('不可用')) return '建议更换讲师或顺延一周';
            if (text.includes('班主任')) return '建议调整到班主任可到场的周末';
            if (text.includes('撞课') || text.includes('冲突')) return '建议同周错开或顺延到下一周';
            return '建议先调整日期，再确认师资安排';
        }

        function buildConflictAssistHtml(sch, isPast) {
            const isConflict = sch.status === 'conflict';
            if (!isConflict) return '';

            const reason = sch.notes || '系统未记录冲突原因';
            const suggestion = getConflictSuggestion(reason);
            const impactScope = `影响班级 ${sch.class_name || '-'}，日期 ${sch.scheduled_date || '-'}`;

            return `
                <div class="mt-2 p-2 rounded-lg bg-red-50 border border-red-200">
                    <div class="text-[11px] text-red-700 font-semibold">冲突原因: ${escapeHtml(reason)}</div>
                    <div class="text-[11px] text-red-600 mt-1">自动建议: ${escapeHtml(suggestion)}</div>
                    <div class="text-[11px] text-slate-500 mt-1">影响范围: ${escapeHtml(impactScope)}</div>
                    ${!isPast ? `
                    <div class="mt-2 flex gap-2">
                        <button onclick="openAdjustModal(${sch.id}); event.stopPropagation();" class="text-[11px] px-2 py-1 bg-white border border-slate-200 rounded hover:bg-slate-50">去调整</button>
                        <button onclick="postponeConflictByWeek(${sch.id}, '${sch.scheduled_date}'); event.stopPropagation();" class="text-[11px] px-2 py-1 bg-white border border-red-200 text-red-600 rounded hover:bg-red-50">顺延一周</button>
                    </div>` : ''}
                </div>
            `;
        }

        async function postponeConflictByWeek(scheduleId, dateStr) {
            try {
                const base = new Date(dateStr);
                const tried = [];

                const allSchedules = (cachedMonthData?.weeks || []).flatMap(w => w.schedules || []);
                const currentSchedule = allSchedules.find(x => x.id === scheduleId) || null;

                function weekLabel(newDateStr) {
                    const d = new Date(newDateStr);
                    const weeks = cachedMonthData?.weeks || [];
                    for (let i = 0; i < weeks.length; i++) {
                        const ws = new Date(weeks[i].week_start);
                        const we = new Date(weeks[i].week_end);
                        if (d >= ws && d <= we) return `Week ${i + 1}`;
                    }
                    return `Cross-month (${newDateStr})`;
                }

                function riskHints(oldDateStr, newDateStr) {
                    const risks = [];
                    const oldDate = new Date(oldDateStr);
                    const newDate = new Date(newDateStr);
                    const gapDays = Math.round((newDate - oldDate) / (24 * 3600 * 1000));

                    if (gapDays > 14) {
                        risks.push(`Gap from current class is ${gapDays} days`);
                    }

                    if (oldDate.getMonth() !== newDate.getMonth()) {
                        risks.push('Moved to next month, check monthly continuity');
                    }

                    if (currentSchedule) {
                        const sameClassDates = allSchedules
                            .filter(x => x.class_id === currentSchedule.class_id && x.id !== scheduleId && x.scheduled_date)
                            .map(x => new Date(x.scheduled_date));

                        if (sameClassDates.length > 0) {
                            const nearest = Math.min(...sameClassDates.map(d => Math.abs(newDate - d)));
                            const nearestDays = Math.round(nearest / (24 * 3600 * 1000));
                            if (nearestDays > 14) {
                                risks.push(`Nearest same-class lesson gap is about ${nearestDays} days`);
                            }
                        }
                    }

                    return risks;
                }

                for (let i = 1; i <= 12; i++) {
                    const d = new Date(base);
                    d.setDate(d.getDate() + i * 7);
                    const newDate = d.toISOString().slice(0, 10);

                    const resp = await fetch(`${API_BASE}/schedule/adjust`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ schedule_id: scheduleId, new_date: newDate })
                    });
                    const data = await resp.json();

                    if (resp.ok && !data.error && !data.warning) {
                        const wk = weekLabel(newDate);
                        const risks = riskHints(dateStr, newDate);
                        const riskText = risks.length
                            ? '\nRisk:\n- ' + risks.join('\n- ')
                            : '\nRisk: no obvious risk detected';

                        await loadMonthSchedule();
                        if (currentClassId) await openClassScheduleModal(currentClassId);
                        alert(`Rescheduled to ${wk} (${newDate})${riskText}`);
                        return;
                    }

                    tried.push(`${weekLabel(newDate)}: ${data.error || data.warning || 'not available'}`);
                }

                const summary = tried.length ? ('\nTried:\n- ' + tried.join('\n- ')) : '';
                alert(`Reschedule failed after 12 weekends.${summary}`);
            } catch (e) {
                alert('Reschedule failed');
            }
        }


        function renderMonthView() {
            const container = document.getElementById('schedule-container');
            const weeks = cachedMonthData.weeks || [];

            if (weeks.length === 0) {
                container.innerHTML = '<div class="text-center text-slate-400 p-8">鏈湀鏆傛棤鎺掕</div>';
                return;
            }

            let html = `
                <div class="flex items-center justify-between mb-6 px-2">
                    <div class="flex items-center gap-4">
                        <span class="text-slate-400 text-sm font-medium">鍏ㄦ湀鎬昏锛堜粎鍛ㄥ叚鏃ワ級</span>
                        <div class="flex gap-3 text-xs opacity-80">
                            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-slate-50 border border-slate-300 border-dashed"></span>棰勬帓</span>
                            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-blue-50 border border-blue-200"></span>宸叉帓</span>
                            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-green-50 border border-green-200"></span>宸茬‘璁?/span>
                        </div>
                    </div>
                    <button onclick="openAddClassModal()" class="flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-bold shadow-md hover:bg-blue-700 transition-all">
                        <i data-lucide="plus" class="w-4 h-4"></i> 鏂板鎺掕
                    </button>
                </div>
                <div class="space-y-6 pb-8">
            `;

            weeks.forEach((w, idx) => {
                const weekStart = new Date(w.week_start);
                const weekEnd = new Date(w.week_end);
                const sat = new Date(weekStart);
                sat.setDate(sat.getDate() + (6 - sat.getDay()));
                const sun = new Date(sat);
                sun.setDate(sun.getDate() + 1);
                const dateRangeStr = `${weekStart.getMonth() + 1}/${weekStart.getDate()} - ${weekEnd.getMonth() + 1}/${weekEnd.getDate()}`;

                html += `
                    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
                        <div class="px-4 py-3 bg-slate-50 border-b flex items-center gap-3">
                            <span class="bg-slate-100 px-2 py-0.5 rounded text-xs text-slate-600 font-bold">绗?${idx + 1} 鍛?/span>
                            <span class="text-sm text-slate-500">${dateRangeStr}</span>
                        </div>
                `;

                if (!w.schedules || w.schedules.length === 0) {
                    html += `<div class="p-5 text-xs text-slate-400 italic">鏈懆鏃犺</div>`;
                } else {
                    html += `
                        <div class="overflow-x-auto">
                            <table class="w-full min-w-[760px] text-sm">
                                <thead class="bg-slate-50 text-slate-600">
                                    <tr>
                                        <th class="text-left px-3 py-2 border-b border-slate-200 w-[30%]">鐝骇/璇鹃</th>
                                        <th class="text-left px-3 py-2 border-b border-slate-200 w-[35%]">鍛ㄥ叚 ${sat.getMonth() + 1}/${sat.getDate()}</th>
                                        <th class="text-left px-3 py-2 border-b border-slate-200 w-[35%]">鍛ㄦ棩 ${sun.getMonth() + 1}/${sun.getDate()}</th>
                                    </tr>
                                </thead>
                                <tbody>
                    `;

                    w.schedules.forEach(sch => {
                        const progress = sch.topic_sequence && sch.total_topics ? `${sch.topic_sequence}/${sch.total_topics}` : '-/-';
                        const isSelected = selectedMergeIds.has(sch.id);
                        const isConflict = sch.status === 'conflict';
                        const isCompleted = sch.status === 'completed' || sch.status === 'confirmed';
                        const isPlanning = sch.status === 'planning';
                        const isPast = new Date(sch.scheduled_date) < new Date(new Date().setHours(0, 0, 0, 0));
                        const rowClass = isSelected ? 'bg-indigo-50' : (isConflict ? 'bg-red-50' : 'bg-white');
                        const day1Teacher = sch.combo ? sch.combo.teacher_name : '寰呭畾';
                        const day1Course = sch.combo ? sch.combo.course_name : '寰呭畾';
                        const day2Teacher = sch.combo_2 ? sch.combo_2.teacher_name : day1Teacher;
                        const day2Course = sch.combo_2 ? sch.combo_2.course_name : day1Course;
                        const statusText = isCompleted ? '已完成' : (isPlanning ? `预排 ${progress}` : `进度 ${progress}`);
                        const conflictAssistHtml = buildConflictAssistHtml(sch, isPast);

                        html += `
                            <tr class="${rowClass} ${isMergeMode ? 'cursor-pointer' : ''}" ${isMergeMode ? `onclick="toggleMergeSelect(${sch.id})"` : ''}>
                                <td class="px-3 py-3 border-b border-slate-100 align-top">
                                    <div class="font-bold text-slate-800">${sch.class_name || '未命名班级'}</div>
                                    <div class="text-xs text-slate-500 mt-1">${sch.topic_name || '寰呭畾璇鹃'}</div>
                                    <div class="text-[11px] text-slate-400 mt-1">班主任: ${sch.homeroom_name || '未分配'}</div>
                                    <div class="text-[11px] mt-2 ${isCompleted ? 'text-green-600' : 'text-blue-600'}">${statusText}</div>
                                    ${conflictAssistHtml}
                                    ${!isPast ? `
                                    <div class="mt-2 flex gap-2">
                                        <button onclick="openAdjustModal(${sch.id}); event.stopPropagation();" class="text-[11px] px-2 py-1 bg-slate-100 hover:bg-slate-200 rounded">缂栬緫</button>
                                        <button onclick="deleteScheduleItem(${sch.id}); event.stopPropagation();" class="text-[11px] px-2 py-1 bg-red-50 hover:bg-red-100 text-red-600 rounded">鍒犻櫎</button>
                                    </div>` : ''}
                                </td>
                                <td class="px-3 py-3 border-b border-slate-100 align-top">
                                    <div class="font-semibold text-slate-700">${day1Teacher}</div>
                                    <div class="text-xs text-slate-500 mt-1">${day1Course}</div>
                                </td>
                                <td class="px-3 py-3 border-b border-slate-100 align-top">
                                    <div class="font-semibold text-slate-700">${day2Teacher}</div>
                                    <div class="text-xs text-slate-500 mt-1">${day2Course}</div>
                                </td>
                            </tr>
                        `;
                    });

                    html += `
                                </tbody>
                            </table>
                        </div>
                    `;
                }

                html += `</div>`;
            });

            html += `
                </div>
                <div class="mt-8 flex justify-end items-center gap-4 px-2 pt-4 border-t border-slate-100">
                    <div class="text-xs text-slate-400">鎸夋湀瑙勫垝鍏ㄥ鏈熸帓璇捐繘搴?/div>
                    <div class="flex gap-3">
                        <button onclick="saveDraft()" class="text-slate-600 text-sm font-bold px-4 py-2 hover:bg-slate-50 rounded-lg">淇濆瓨鑽夌</button>
                        <button onclick="openPublishPreview()" class="bg-green-600 text-white text-sm font-bold px-6 py-2 rounded-lg hover:bg-green-700 shadow-md transition-transform active:scale-95">鍙戝竷鏈堝害璁″垝</button>
                    </div>
                </div>
            `;

            container.innerHTML = html;
            lucide.createIcons();
        }

        function renderWeekView() {
            const container = document.getElementById('schedule-container');
            const weeks = cachedMonthData.weeks || [];

            if (weeks.length === 0) {
                container.innerHTML = '<div class="text-center text-slate-400 p-8">鏈湀鏆傛棤鎺掕</div>';
                return;
            }

            const w = weeks[currentWeekIndex];
            if (!w) return;

            const weekStart = new Date(w.week_start);
            const weekEnd = new Date(w.week_end);
            const sat = new Date(weekStart);
            sat.setDate(sat.getDate() + (6 - sat.getDay()));
            const sun = new Date(sat);
            sun.setDate(sun.getDate() + 1);
            const dateRangeStr = `${weekStart.getMonth() + 1}/${weekStart.getDate()} - ${weekEnd.getMonth() + 1}/${weekEnd.getDate()}`;

            let html = `
                <div class="flex items-center justify-between mb-6 px-2">
                    <div class="flex items-center gap-4">
                        <div class="flex bg-white rounded-lg border p-1 shadow-sm">
                            <button onclick="changeWeek(-1)" class="p-1 px-3 hover:bg-slate-50 rounded text-slate-600 ${currentWeekIndex === 0 ? 'opacity-30 cursor-not-allowed' : ''}" ${currentWeekIndex === 0 ? 'disabled' : ''}>
                                <i data-lucide="chevron-left" class="w-5 h-5"></i>
                            </button>
                            <span class="px-4 py-1 text-sm font-bold text-slate-700 border-x border-slate-100 flex items-center">
                                绗?${currentWeekIndex + 1} 鍛?
                            </span>
                            <button onclick="changeWeek(1)" class="p-1 px-3 hover:bg-slate-50 rounded text-slate-600 ${currentWeekIndex === weeks.length - 1 ? 'opacity-30 cursor-not-allowed' : ''}" ${currentWeekIndex === weeks.length - 1 ? 'disabled' : ''}>
                                <i data-lucide="chevron-right" class="w-5 h-5"></i>
                            </button>
                        </div>
                        <span class="text-slate-400 text-sm font-medium">${dateRangeStr}</span>
                    </div>
                    <button onclick="openAddClassModal()" class="flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-bold shadow-md hover:bg-blue-700 transition-all">
                        <i data-lucide="plus" class="w-4 h-4"></i> 鏂板鎺掕
                    </button>
                </div>
            `;

            if (!w.schedules || w.schedules.length === 0) {
                html += `
                    <div class="min-h-[300px] flex flex-col items-center justify-center border-2 border-dashed border-slate-200 rounded-2xl m-4 bg-slate-50/50">
                        <div class="text-slate-400 text-sm mb-4">鏈懆鏆傛棤璇剧▼瀹夋帓</div>
                        <button onclick="openAddClassModal()" class="text-blue-600 font-bold text-sm hover:underline">绔嬪嵆鎺掕</button>
                    </div>
                `;
            } else {
                html += `
                    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden mx-2">
                        <div class="overflow-x-auto">
                            <table class="w-full min-w-[760px] text-sm">
                                <thead class="bg-slate-50 text-slate-600">
                                    <tr>
                                        <th class="text-left px-3 py-2 border-b border-slate-200 w-[30%]">鐝骇/璇鹃</th>
                                        <th class="text-left px-3 py-2 border-b border-slate-200 w-[35%]">鍛ㄥ叚 ${sat.getMonth() + 1}/${sat.getDate()}</th>
                                        <th class="text-left px-3 py-2 border-b border-slate-200 w-[35%]">鍛ㄦ棩 ${sun.getMonth() + 1}/${sun.getDate()}</th>
                                    </tr>
                                </thead>
                                <tbody>
                `;

                w.schedules.forEach(sch => {
                    const progress = sch.topic_sequence && sch.total_topics ? `${sch.topic_sequence}/${sch.total_topics}` : '-/-';
                    const isSelected = selectedMergeIds.has(sch.id);
                    const isConflict = sch.status === 'conflict';
                    const isCompleted = sch.status === 'completed' || sch.status === 'confirmed';
                    const isPlanning = sch.status === 'planning';
                    const isPast = new Date(sch.scheduled_date) < new Date(new Date().setHours(0, 0, 0, 0));
                    const rowClass = isSelected ? 'bg-indigo-50' : (isConflict ? 'bg-red-50' : 'bg-white');
                    const day1Teacher = sch.combo ? sch.combo.teacher_name : '寰呭畾';
                    const day1Course = sch.combo ? sch.combo.course_name : '寰呭畾';
                    const day2Teacher = sch.combo_2 ? sch.combo_2.teacher_name : day1Teacher;
                    const day2Course = sch.combo_2 ? sch.combo_2.course_name : day1Course;
                    const statusText = isCompleted ? '已完成' : (isPlanning ? `预排 ${progress}` : `进度 ${progress}`);
                    const conflictAssistHtml = buildConflictAssistHtml(sch, isPast);

                    html += `
                        <tr class="${rowClass} ${isMergeMode ? 'cursor-pointer' : ''}" ${isMergeMode ? `onclick="toggleMergeSelect(${sch.id})"` : ''}>
                            <td class="px-3 py-3 border-b border-slate-100 align-top">
                                <div class="font-bold text-slate-800">${sch.class_name || '未命名班级'}</div>
                                <div class="text-xs text-slate-500 mt-1">${sch.topic_name || '寰呭畾璇鹃'}</div>
                                <div class="text-[11px] text-slate-400 mt-1">班主任: ${sch.homeroom_name || '未分配'}</div>
                                <div class="text-[11px] mt-2 ${isCompleted ? 'text-green-600' : 'text-blue-600'}">${statusText}</div>
                                    ${conflictAssistHtml}
                                <div class="mt-2 flex gap-2">
                                    ${!isPast ? `
                                    <button onclick="openAdjustModal(${sch.id}); event.stopPropagation();" class="text-[11px] px-2 py-1 bg-slate-100 hover:bg-slate-200 rounded">缂栬緫</button>
                                    <button onclick="deleteScheduleItem(${sch.id}); event.stopPropagation();" class="text-[11px] px-2 py-1 bg-red-50 hover:bg-red-100 text-red-600 rounded">鍒犻櫎</button>` : ''}
                                    ${sch.merged_with
                            ? `<button onclick="unmergeSchedule(${sch.id}); event.stopPropagation();" class="text-[11px] px-2 py-1 bg-purple-50 hover:bg-purple-100 text-purple-600 rounded">鎷嗗垎</button>`
                            : ''}
                                </div>
                            </td>
                            <td class="px-3 py-3 border-b border-slate-100 align-top">
                                <div class="font-semibold text-slate-700">${day1Teacher}</div>
                                <div class="text-xs text-slate-500 mt-1">${day1Course}</div>
                            </td>
                            <td class="px-3 py-3 border-b border-slate-100 align-top">
                                <div class="font-semibold text-slate-700">${day2Teacher}</div>
                                <div class="text-xs text-slate-500 mt-1">${day2Course}</div>
                            </td>
                        </tr>
                    `;
                });

                html += `
                                </tbody>
                            </table>
                        </div>
                    </div>
                `;
            }

            html += `
                <div class="mt-8 flex justify-end items-center gap-4 px-2 pt-4 border-t border-slate-100">
                    <div class="text-xs text-slate-400">鎸夋湀瑙勫垝鍏ㄥ鏈熸帓璇捐繘搴?/div>
                    <div class="flex gap-3">
                        <button onclick="saveDraft()" class="text-slate-600 text-sm font-bold px-4 py-2 hover:bg-slate-50 rounded-lg">淇濆瓨鑽夌</button>
                        <button onclick="openPublishPreview()" class="bg-green-600 text-white text-sm font-bold px-6 py-2 rounded-lg hover:bg-green-700 shadow-md transition-transform active:scale-95">鍙戝竷鏈堝害璁″垝</button>
                    </div>
                </div>
            `;

            container.innerHTML = html;
            lucide.createIcons();
        }

        function saveDraft() {
            alert('草稿已保存');
        }

        function renderPublishChecklist(checklist) {
            const unresolved = checklist.unresolved || [];
            const pending = checklist.pending || [];
            const resolved = checklist.resolved || [];

            const unresolvedHtml = unresolved.length ? unresolved.map((item, idx) => `
                <div class="border border-red-200 bg-red-50/60 rounded-lg p-3">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <div class="text-sm font-bold text-red-700">${item.class_name || '-'} 路 ${item.topic_name || '-'}</div>
                            <div class="text-xs text-slate-500 mt-1">鏃ユ湡: ${item.date || '-'} | 褰卞搷鑼冨洿: ${item.impact_scope || '-'}</div>
                        </div>
                        <button type="button" onclick="document.getElementById('conflict-reason-${idx}').classList.toggle('hidden')" class="text-xs px-2 py-1 bg-white border rounded text-slate-600">鏌ョ湅鍘熷洜</button>
                    </div>
                    <div id="conflict-reason-${idx}" class="hidden mt-2 text-xs text-slate-700 bg-white border rounded p-2">
                        <div><span class="font-semibold">鍘熷洜:</span> ${item.reason || '-'}</div>
                        <div class="mt-1"><span class="font-semibold">鑷姩寤鸿:</span> ${item.suggestion || '-'}</div>
                    </div>
                </div>
            `).join('') : '<div class="text-xs text-green-700 bg-green-50 border border-green-200 rounded-lg p-3">鏃犳棤娉曡В鍐冲啿绐?/div>';

            const pendingHtml = pending.length ? pending.map(item => `
                <div class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded p-2">${item.class_name || '-'} 路 ${item.topic_name || '-'} 路 ${item.date || '-'}锛堝緟纭锛?/div>
            `).join('') : '<div class="text-xs text-slate-400">鏃犲緟纭椤?/div>';

            const resolvedHtml = resolved.length ? `<div class="text-xs text-slate-600">宸茶В鍐?${resolved.length} 椤?/div>` : '<div class="text-xs text-slate-400">鏃犲凡瑙ｅ喅椤?/div>';

            return `
                <div class="mt-4 space-y-3">
                    <div class="bg-white border rounded-xl p-3">
                        <div class="font-bold text-sm text-red-700 mb-2">鏃犳硶瑙ｅ喅锛堥粯璁ら樆姝㈠彂甯冿級</div>
                        <div class="space-y-2">${unresolvedHtml}</div>
                    </div>
                    <div class="bg-white border rounded-xl p-3">
                        <div class="font-bold text-sm text-amber-700 mb-2">寰呯‘璁?/div>
                        <div class="space-y-2">${pendingHtml}</div>
                    </div>
                    <div class="bg-white border rounded-xl p-3">
                        <div class="font-bold text-sm text-slate-700 mb-2">宸茶В鍐?/div>
                        ${resolvedHtml}
                    </div>
                </div>
            `;
        }

        function updatePublishControls() {
            const unresolved = publishChecklistState.unresolved || [];
            const forceBox = document.getElementById('publish-force-controls');
            const forceCheck = document.getElementById('force-publish-all');
            const forceNote = document.getElementById('force-publish-note');
            const tip = document.getElementById('publish-block-tip');
            const btn = document.getElementById('publish-confirm-btn');

            if (!unresolved.length) {
                forceBox.classList.add('hidden');
                tip.classList.add('hidden');
                btn.disabled = false;
                btn.classList.remove('opacity-50', 'cursor-not-allowed');
                return;
            }

            forceBox.classList.remove('hidden');
            const allowed = forceCheck.checked && forceNote.value.trim().length > 0;
            if (!allowed) {
                btn.disabled = true;
                btn.classList.add('opacity-50', 'cursor-not-allowed');
                tip.textContent = '存在无法解决冲突。请勾选强制发布并填写备注。';
                tip.classList.remove('hidden');
            } else {
                btn.disabled = false;
                btn.classList.remove('opacity-50', 'cursor-not-allowed');
                tip.classList.add('hidden');
            }
        }

        async function openPublishPreview() {
            if (!cachedMonthData || !(cachedMonthData.weeks || []).length) {
                alert('褰撳墠娌℃湁鍙彂甯冪殑鎺掕鏁版嵁');
                return;
            }

            const preview = document.getElementById('publish-preview-content');
            const forceCheck = document.getElementById('force-publish-all');
            const forceNote = document.getElementById('force-publish-note');
            forceCheck.checked = false;
            forceNote.value = '';

            let checklist = { unresolved: [], pending: [], resolved: [] };
            try {
                const ckResp = await fetch(`${API_BASE}/schedule/publish-checklist?year=${currentYear}&month=${currentMonth}`);
                if (ckResp.ok) {
                    const ckData = await ckResp.json();
                    checklist = ckData.checklist || checklist;
                }
            } catch (e) {
                console.error(e);
            }
            publishChecklistState = checklist;

            const weeks = cachedMonthData.weeks || [];
            let html = `
                <div class="mb-4 text-sm text-slate-600">${cachedMonthData.year}骞?{cachedMonthData.month}鏈堝彂甯冮瑙堬紙鍛ㄥ叚/鍛ㄦ棩锛?/div>
                <div class="space-y-4">
            `;

            weeks.forEach((w, idx) => {
                const weekStart = new Date(w.week_start);
                const sat = new Date(weekStart);
                sat.setDate(sat.getDate() + (6 - sat.getDay()));
                const sun = new Date(sat);
                sun.setDate(sun.getDate() + 1);

                const satItems = (w.schedules || []).map(sch => {
                    const teacher = sch.combo ? sch.combo.teacher_name : '寰呭畾';
                    const course = sch.combo ? sch.combo.course_name : '寰呭畾';
                    return `<div class="text-xs text-slate-700 mb-1"><span class="font-semibold">${sch.class_name}</span> 路 ${teacher} 路 ${course}</div>`;
                }).join('') || '<div class="text-xs text-slate-400">鏃?/div>';

                const sunItems = (w.schedules || []).map(sch => {
                    const teacher = sch.combo_2 ? sch.combo_2.teacher_name : (sch.combo ? sch.combo.teacher_name : '寰呭畾');
                    const course = sch.combo_2 ? sch.combo_2.course_name : (sch.combo ? sch.combo.course_name : '寰呭畾');
                    return `<div class="text-xs text-slate-700 mb-1"><span class="font-semibold">${sch.class_name}</span> 路 ${teacher} 路 ${course}</div>`;
                }).join('') || '<div class="text-xs text-slate-400">鏃?/div>';

                html += `
                    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
                        <div class="px-3 py-2 bg-slate-50 border-b text-xs font-bold text-slate-600">绗?${idx + 1} 鍛?/div>
                        <div class="grid grid-cols-2">
                            <div class="p-3 border-r border-slate-100">
                                <div class="text-xs font-bold text-blue-600 mb-2">鍛ㄥ叚 ${sat.getMonth() + 1}/${sat.getDate()}</div>
                                ${satItems}
                            </div>
                            <div class="p-3">
                                <div class="text-xs font-bold text-orange-600 mb-2">鍛ㄦ棩 ${sun.getMonth() + 1}/${sun.getDate()}</div>
                                ${sunItems}
                            </div>
                        </div>
                    </div>
                `;
            });

            html += `</div>` + renderPublishChecklist(checklist);
            preview.innerHTML = html;
            document.getElementById('publish-preview-modal').classList.add('active');

            forceCheck.onchange = updatePublishControls;
            forceNote.oninput = updatePublishControls;
            updatePublishControls();
            lucide.createIcons();
        }

        function closePublishPreview() {
            document.getElementById('publish-preview-modal').classList.remove('active');
        }

        async function executePublishMonth() {
            const unresolved = publishChecklistState.unresolved || [];
            const forceCheck = document.getElementById('force-publish-all');
            const forceNote = document.getElementById('force-publish-note');

            const payload = {
                year: currentYear,
                month: currentMonth,
                force_publish: unresolved.length > 0,
                force_note: forceNote.value.trim()
            };

            if (unresolved.length > 0) {
                if (!forceCheck.checked || !payload.force_note) {
                    updatePublishControls();
                    return;
                }
            }

            try {
                const resp = await fetch(`${API_BASE}/schedule/publish`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await resp.json();
                if (resp.ok) {
                    closePublishPreview();
                    alert(data.message || '月度计划已发布');
                    loadMonthSchedule();
                    return;
                }

                if (resp.status === 409 && data.code === 'UNRESOLVED_CONFLICTS') {
                    publishChecklistState = data.checklist || publishChecklistState;
                    updatePublishControls();
                    alert('存在无法解决冲突，默认阻止发布。请勾选强制发布并填写备注。');
                    return;
                }

                alert(data.error || '鍙戝竷澶辫触');
            } catch (e) {
                alert('鍙戝竷澶辫触');
            }
        }

        function toggleMergeMode() {
            isMergeMode = !isMergeMode;
            selectedMergeIds.clear();

            const btn = document.getElementById('merge-mode-btn');
            const confirmBtn = document.getElementById('confirm-merge-btn');

            if (isMergeMode) {
                btn.innerHTML = `<i data-lucide="x" class="w-3 h-3"></i> 鍙栨秷`;
                btn.className = "px-3 py-1.5 text-xs font-bold bg-slate-100 text-slate-600 rounded-lg hover:bg-slate-200 transition-all flex items-center gap-1";
            } else {
                btn.innerHTML = `<i data-lucide="layers" class="w-3 h-3"></i> 鍚堢彮妯″紡`;
                btn.className = "px-3 py-1.5 text-xs font-bold bg-purple-100 text-purple-600 rounded-lg hover:bg-purple-200 transition-all flex items-center gap-1";
                confirmBtn.classList.add('hidden');
            }

            lucide.createIcons();
            loadMonthSchedule();
        }

        function toggleMergeSelect(id) {
            if (selectedMergeIds.has(id)) {
                selectedMergeIds.delete(id);
            } else {
                selectedMergeIds.add(id);
            }

            // 鏇存柊纭鎸夐挳鐘舵€?
            const confirmBtn = document.getElementById('confirm-merge-btn');
            const countSpan = document.getElementById('merge-count');

            if (selectedMergeIds.size >= 2) {
                confirmBtn.classList.remove('hidden');
            } else {
                confirmBtn.classList.add('hidden');
            }
            countSpan.textContent = selectedMergeIds.size;

            // 灞€閮ㄩ噸鏂版覆鏌撹繃浜庡鏉傦紝鐩存帴閲嶆柊鍔犺浇
            loadMonthSchedule();
        }

        async function executeMerge() {
            if (selectedMergeIds.size < 2) return;
            if (!confirm(`确定合并选中的 ${selectedMergeIds.size} 个班级课程吗？\n合并后将统一上课时间和师资。`)) return;

            try {
                const resp = await fetch(`${API_BASE}/schedule/merge`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        schedule_ids: Array.from(selectedMergeIds)
                    })
                });

                if (resp.ok) {
                    alert('鍚堢彮鎴愬姛');
                    toggleMergeMode(); // 閫€鍑哄悎骞舵ā寮?
                } else {
                    const err = await resp.json();
                    alert('鍚堢彮澶辫触: ' + (err.error || '鏈煡閿欒'));
                }
            } catch (e) {
                alert('鍚堢彮澶辫触');
            }
        }

        async function unmergeSchedule(id) {
            if (!confirm('确定取消该课程的合班状态吗？')) return;
            try {
                await fetch(`${API_BASE}/schedule/unmerge/${id}`, { method: 'POST' });
                loadMonthSchedule();
            } catch (e) {
                alert('操作失败');
            }
        }



        // ==================== 璋冩暣璇剧▼ ====================
        async function openAdjustModal(scheduleId) {
            currentScheduleId = scheduleId;
            try {
                // 1. 鑾峰彇璇剧▼璇︽儏
                const schedResp = await fetch(`${API_BASE}/schedule/${scheduleId}`);
                if (!schedResp.ok) throw new Error('鑾峰彇璇剧▼璇︽儏澶辫触');
                const schedule = await schedResp.json();

                document.getElementById('adjust-schedule-info').innerHTML = `
                    <div class="font-bold text-slate-800">${schedule.class_name}</div>
                    <div class="text-sm font-semibold text-blue-600">${schedule.topic_name}</div>
                    <div class="text-xs text-slate-500 mt-1">褰撳墠鎺掕: ${schedule.scheduled_date}</div>
                `;
                document.getElementById('adjust-new-date').value = schedule.scheduled_date;

                // 2. 鍔犺浇璇ヨ棰樹笅鐨勫彲閫夋暀-璇剧粍鍚?
                const combosResp = await fetch(`${API_BASE}/combos?topic_id=${schedule.topic_id}`);
                const combos = await combosResp.json();

                // 3. 濉厖涓嬫媺妗?
                const comboSelect = document.getElementById('adjust-combo');
                if (combos.length === 0) {
                    comboSelect.innerHTML = '<option value="">-- 璇ヨ棰樻殏鏃犳暀-璇剧粍鍚?璇烽噸鏂伴厤缃? --</option>';
                } else {
                    comboSelect.innerHTML = '<option value="">-- 淇濇寔涓嶅彉 --</option>' +
                        combos.map(c => `
                            <option value="${c.id}" ${schedule.combo_id === c.id ? 'selected' : ''}>
                                ${c.teacher_name} - ${c.course_name}
                            </option>
                        `).join('');
                }

                document.getElementById('adjust-schedule-modal').classList.add('active');
                lucide.createIcons();
            } catch (e) {
                console.error(e);
                alert('鍔犺浇璇︽儏澶辫触: ' + e.message);
            }
        }

        function closeAdjustModal() {
            document.getElementById('adjust-schedule-modal').classList.remove('active');
        }

        async function moveScheduleWeek(direction) {
            try {
                await fetch(`${API_BASE}/schedule/move-week`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ schedule_id: currentScheduleId, direction })
                });
                closeAdjustModal();
                loadMonthSchedule();
                if (currentClassId) openClassScheduleModal(currentClassId);
            } catch (e) {
                alert('璋冩暣澶辫触');
            }
        }

        async function saveAdjustment() {
            const newDate = document.getElementById('adjust-new-date').value;
            const comboId = document.getElementById('adjust-combo').value;

            try {
                await fetch(`${API_BASE}/schedule/adjust`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        schedule_id: currentScheduleId,
                        new_date: newDate || undefined,
                        combo_id: comboId ? parseInt(comboId) : undefined
                    })
                });
                closeAdjustModal();
                loadMonthSchedule();
            } catch (e) {
                alert('淇濆瓨澶辫触');
            }
        }

        // ==================== AI 鏅鸿兘鎺掕 ====================
        async function smartGenerateSchedule(event) {
            if (event) event.preventDefault();

            const btn = document.getElementById('smart-generate-btn');
            if (btn.disabled) return;

            const prompt = document.getElementById('prompt-input').value.trim();

            // 鍏佽涓虹┖锛屼綔涓衡€滄棤鐗规畩瑕佹眰鈥濆鐞?
            // if (!prompt) {
            //     alert('璇疯緭鍏ユ彁绀鸿瘝锛屾垨鑰呮弿杩?鏃犵壒娈婅姹?');
            //     return;
            // }

            btn.disabled = true;
            btn.innerHTML = '<span class="loading"></span> ' + (prompt ? 'AI 姝ｅ湪鎬濊€冨苟鎺掕...' : '姝ｅ湪蹇€熺敓鎴愯琛?..');

            const resultBox = document.getElementById('constraints-result');
            resultBox.classList.add('hidden');

            try {
                // 0. 鍑嗗涓婁笅鏂囨暟鎹?
                const [teachersResp, homeroomsResp, classesResp] = await Promise.all([
                    fetch(`${API_BASE}/teachers`),
                    fetch(`${API_BASE}/homerooms`),
                    fetch(`${API_BASE}/classes`)
                ]);

                const teachersData = await teachersResp.json();
                const homeroomsData = await homeroomsResp.json();
                const classesData = await classesResp.json();

                const context = {
                    current_month: `${currentYear}-${String(currentMonth).padStart(2, '0')}`,
                    teachers: teachersData.map(t => t.name),
                    homeroom_teachers: homeroomsData.map(h => h.name),
                    classes: classesData.map(c => c.name)
                };

                // 1. 鎻愬彇绾︽潫
                const resp = await fetch(`${API_BASE}/ai/extract-constraints`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ prompt, context })
                });

                if (!resp.ok) {
                    const err = await resp.json();
                    throw new Error(err.error || 'AI鏈嶅姟璇锋眰澶辫触');
                }

                const data = await resp.json();

                // 2. 鏄剧ず鎻愬彇缁撴灉
                let html = '';
                if (data.constraints) {
                    if (data.constraints.blocked_dates?.length) {
                        html += '<div class="mb-1">馃搮 <strong>閬垮紑鏃ユ湡锛?/strong>' + data.constraints.blocked_dates.map(d => `${d.date}(${d.reason})`).join(', ') + '</div>';
                    }
                    if (data.constraints.teacher_unavailable?.length) {
                        html += '<div class="mb-1">馃毇 <strong>璁插笀璇峰亣锛?/strong>' + data.constraints.teacher_unavailable.map(t => `${t.teacher_name}: ${t.dates.join(',')}`).join('; ') + '</div>';
                    }
                    if (data.constraints.homeroom_unavailable?.length) {
                        html += '<div class="mb-1">馃毇 <strong>鐝富浠昏鍋囷細</strong>' + data.constraints.homeroom_unavailable.map(h => `${h.homeroom_name}: ${h.dates.join(',')}`).join('; ') + '</div>';
                    }
                }
                document.getElementById('constraints-content').innerHTML = html || '未识别到具体约束，将按默认规则排课。';
                resultBox.classList.remove('hidden');

                const conflictMode = document.getElementById('conflict-mode').value;

                // 3. 璋冪敤鍚庣鐢熸垚鎺ュ彛锛屽簲鐢ㄧ害鏉?
                const genResp = await fetch(`${API_BASE}/schedule/generate`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        year: currentYear,
                        month: currentMonth,
                        constraints: data.constraints || {},
                        conflict_mode: conflictMode
                    })
                });

                if (!genResp.ok) throw new Error('鎺掕鐢熸垚澶辫触');
                const genResult = await genResp.json();

                // 4. 鍒锋柊璇捐〃
                await loadMonthSchedule();

                // 5. 鏄剧ず鎺掕缁撴灉鍙嶉 (鐗瑰埆鏄湭鎺掕鐨勭彮绾?
                let msg = `排课完成：${genResult.message}`;
                const constraintsBox = document.getElementById('constraints-content');

                if (genResult.skipped && genResult.skipped.length > 0) {
                    let warnHtml = `<div class="mt-4 p-3 bg-red-50 border border-red-200 rounded-lg text-xs text-red-700">
                        <div class="font-bold flex items-center gap-2 mb-2 text-sm">
                            <i data-lucide="clock" class="w-4 h-4 text-red-600"></i>
                            浠ヤ笅鐝骇鏈湀鏃犲悎閫傛。鏈燂紝宸茶嚜鍔ㄩ『寤惰嚦涓嬫湀 (璇剧▼杩涘害淇濈暀):
                        </div>
                        <ul class="list-disc list-inside space-y-1">`;

                    genResult.skipped.forEach(item => {
                        warnHtml += `<li><strong>${item.class_name}</strong>: ${item.reason}</li>`;
                    });
                    warnHtml += `</ul></div>`;

                    constraintsBox.innerHTML += warnHtml;
                    resultBox.classList.remove('hidden'); // 纭繚鏄剧ず
                    msg += `\n\n注意：有 ${genResult.skipped.length} 个班级未能安排档期，详情请见左侧提示面板。`;
                }

                alert(msg);

            } catch (e) {
                console.error(e);
                alert('鏅鸿兘鎺掕澶辫触: ' + e.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i data-lucide="sparkles" class="w-4 h-4"></i> 鏅鸿兘閲嶆柊鐢熸垚璇捐〃';
                lucide.createIcons();
            }
        }

        // ==================== 鍩虹鏁版嵁绠＄悊 ====================
        async function loadHomerooms() {
            try {
                const resp = await fetch(`${API_BASE}/homerooms`);
                const data = await resp.json();
                document.getElementById('homerooms-list').innerHTML = data.map(h => `
                    <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                        <div class="flex items-center gap-2">
                            <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center text-sm font-bold">${h.name[0]}</div>
                            <span class="text-sm">${h.name}</span>
                        </div>
                        <button onclick="deleteHomeroom(${h.id})" class="text-red-500 text-xs">鍒犻櫎</button>
                    </div>
                `).join('');
            } catch (e) { }
        }

        async function addHomeroom() {
            const name = document.getElementById('new-homeroom-name').value.trim();
            if (!name) return;
            await fetch(`${API_BASE}/homerooms`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name }) });
            document.getElementById('new-homeroom-name').value = '';
            loadHomerooms();
        }

        async function deleteHomeroom(id) {
            if (!confirm('确定删除该班主任吗？')) return;
            await fetch(`${API_BASE}/homerooms/${id}`, { method: 'DELETE' });
            loadHomerooms();
        }

        async function loadTeachers() {
            try {
                const resp = await fetch(`${API_BASE}/teachers`);
                const data = await resp.json();
                document.getElementById('teachers-list').innerHTML = data.map(t => `
                    <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                        <div>
                            <span class="text-sm font-medium">${t.name}</span>
                            <span class="text-[10px] text-slate-500 ml-2">${t.title || ''}</span>
                        </div>
                        <button onclick="deleteTeacher(${t.id})" class="text-red-500 text-xs">鍒犻櫎</button>
                    </div>
                `).join('');
            } catch (e) { }
        }

        async function addTeacher() {
            const name = document.getElementById('new-teacher-name').value.trim();
            if (!name) return;
            await fetch(`${API_BASE}/teachers`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name }) });
            document.getElementById('new-teacher-name').value = '';
            loadTeachers();
        }

        async function deleteTeacher(id) {
            if (!confirm('确定删除该讲师吗？')) return;
            await fetch(`${API_BASE}/teachers/${id}`, { method: 'DELETE' });
            loadTeachers();
        }

        async function loadCourses() {
            try {
                // 骞惰鍔犺浇璇剧▼鍜屽煿璁彮绫诲瀷(鍚棰?
                const [coursesResp, typesResp] = await Promise.all([
                    fetch(`${API_BASE}/courses`),
                    fetch(`${API_BASE}/training-types`)
                ]);

                const courses = await coursesResp.json();
                const types = await typesResp.json();

                // 1. 濉厖璇鹃涓嬫媺妗?
                const topicSelect = document.getElementById('new-course-topic');
                const filterSelect = document.getElementById('course-topic-filter');

                // 淇濆瓨褰撳墠閫変腑鐨勭瓫閫夊€?
                const currentFilterValue = filterSelect.value;

                let optionsHtml = '<option value="">-- 閫夋嫨鎵€灞炶棰?--</option>';
                let filterOptionsHtml = '<option value="">-- 鍏ㄩ儴璇鹃 --</option>';
                const topicMap = new Map(); // id -> {name, type_name}

                types.forEach(type => {
                    if (type.topics) {
                        type.topics.forEach(topic => {
                            topicMap.set(topic.id, { name: topic.name, type_name: type.name });
                            optionsHtml += `<option value="${topic.id}">[${type.name}] ${topic.name}</option>`;
                            filterOptionsHtml += `<option value="${topic.id}">[${type.name}] ${topic.name}</option>`;
                        });
                    }
                });

                topicSelect.innerHTML = optionsHtml;
                filterSelect.innerHTML = filterOptionsHtml;

                // 鎭㈠涔嬪墠鐨勭瓫閫夊€?
                if (currentFilterValue) {
                    filterSelect.value = currentFilterValue;
                }

                // Store globally for filtering
                window._courseData = { courses, topicMap };

                // 2. 鎸夎棰樺垎缁勫睍绀鸿绋?
                const coursesByTopic = {};
                const unassignedCourses = [];

                // 璇诲彇绛涢€夊櫒鐨勫€?
                const filterTopicId = document.getElementById('course-topic-filter')?.value;
                const filterTopicIdNum = filterTopicId ? parseInt(filterTopicId) : null;

                // 鎸夊煿璁彮绫诲瀷鍐嶅垎缁?
                const coursesByType = {};

                courses.forEach(c => {
                    // 濡傛灉鏈夌瓫閫夛紝鍙樉绀虹瓫閫夌殑璇鹃涓嬬殑璇剧▼
                    if (filterTopicIdNum && c.topic_id !== filterTopicIdNum) {
                        return; // 璺宠繃
                    }

                    if (c.topic_id && topicMap.has(c.topic_id)) {
                        const info = topicMap.get(c.topic_id);
                        const typeKey = info.type_name;
                        if (!coursesByType[typeKey]) coursesByType[typeKey] = {};
                        if (!coursesByType[typeKey][c.topic_id]) coursesByType[typeKey][c.topic_id] = { topicName: info.name, courses: [] };
                        coursesByType[typeKey][c.topic_id].courses.push(c);
                    } else {
                        unassignedCourses.push(c);
                    }
                });

                let html = '';
                const typeColors = ['bg-blue-600', 'bg-green-600', 'bg-purple-600', 'bg-orange-600', 'bg-pink-600', 'bg-teal-600', 'bg-indigo-600'];
                let colorIdx = 0;

                // 鎸夊煿璁彮绫诲瀷鍒嗙粍灞曠ず
                for (const [typeName, topics] of Object.entries(coursesByType)) {
                    const color = typeColors[colorIdx % typeColors.length];
                    colorIdx++;

                    html += `
                        <div class="mb-4 border rounded-xl overflow-hidden shadow-sm">
                            <!-- 鍩硅鐝被鍨嬫爣棰?-->
                            <div class="${color} text-white px-3 py-2 flex items-center justify-between cursor-pointer" onclick="this.nextElementSibling.classList.toggle('hidden')">
                                <div class="flex items-center gap-2">
                                    <i data-lucide="graduation-cap" class="w-4 h-4"></i>
                                    <span class="font-bold text-sm">${typeName}</span>
                                </div>
                                <i data-lucide="chevron-down" class="w-4 h-4"></i>
                            </div>
                            <!-- 璇鹃鍒楄〃 -->
                            <div class="bg-white divide-y divide-slate-100">
                    `;

                    for (const [topicId, topicData] of Object.entries(topics)) {
                        html += `
                                <div class="p-2">
                                    <!-- 璇鹃鏍囬 -->
                                    <div class="flex items-center gap-2 px-2 py-1 bg-slate-50 rounded-lg mb-2">
                                        <i data-lucide="book-open" class="w-3 h-3 text-slate-400"></i>
                                        <span class="text-xs font-semibold text-slate-600">${topicData.topicName}</span>
                                        <span class="text-[10px] bg-slate-200 text-slate-500 px-1.5 rounded">${topicData.courses.length}门?/span>
                                    </div>
                                    <!-- 璇剧▼鍒楄〃 -->
                                    <div class="space-y-1 pl-3">
                                        ${topicData.courses.map(c => `
                                            <div class="flex items-center justify-between p-2 bg-white border border-slate-100 rounded-lg hover:border-blue-300 hover:shadow-sm transition-all group">
                                                <div class="flex items-center gap-2">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
                                                    <span class="text-sm text-slate-700">${c.name}</span>
                                                </div>
                                                <button onclick="deleteCourse(${c.id})" class="text-slate-300 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity">
                                                    <i data-lucide="trash-2" class="w-3 h-3"></i>
                                                </button>
                                            </div>
                                        `).join('')}
                                    </div>
                                </div>
                        `;
                    }

                    html += `
                            </div>
                        </div>
                    `;
                }

                // 鏈垎閰嶈棰樼殑璇剧▼
                if (unassignedCourses.length > 0) {
                    html += `
                        <div class="mb-4 border border-dashed border-slate-300 rounded-xl overflow-hidden">
                            <div class="bg-slate-100 text-slate-500 px-3 py-2 flex items-center gap-2">
                                <i data-lucide="alert-circle" class="w-4 h-4"></i>
                                <span class="font-bold text-sm">鏈垎绫昏绋?/span>
                                <span class="text-[10px] bg-slate-200 px-1.5 rounded">${unassignedCourses.length}</span>
                            </div>
                            <div class="p-2 space-y-1">
                                ${unassignedCourses.map(c => `
                                    <div class="flex items-center justify-between p-2 bg-slate-50 rounded-lg opacity-70 group">
                                        <span class="text-sm text-slate-500">${c.name}</span>
                                        <button onclick="deleteCourse(${c.id})" class="text-slate-300 hover:text-red-500 opacity-0 group-hover:opacity-100">
                                            <i data-lucide="trash-2" class="w-3 h-3"></i>
                                        </button>
                                    </div>
                                `).join('')}
                            </div>
                        </div>
                    `;
                }

                if (!html) html = '<div class="text-center text-slate-400 text-xs p-4">鏆傛棤璇剧▼鏁版嵁</div>';

                document.getElementById('courses-list').innerHTML = html;
                lucide.createIcons();

            } catch (e) {
                console.error(e);
                document.getElementById('courses-list').innerHTML = '<div class="text-red-500 text-xs p-2">鍔犺浇澶辫触</div>';
            }
        }

        async function addCourse() {
            const name = document.getElementById('new-course-name').value.trim();
            const topicId = document.getElementById('new-course-topic').value;

            if (!name) {
                alert('请输入课程名称');
                return;
            }

            try {
                const resp = await fetch(`${API_BASE}/courses`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        name,
                        topic_id: topicId ? parseInt(topicId) : null
                    })
                });

                if (resp.ok) {
                    document.getElementById('new-course-name').value = '';
                    loadCourses();
                } else {
                    alert('娣诲姞澶辫触');
                }
            } catch (e) {
                alert('娣诲姞閿欒: ' + e.message);
            }
        }

        async function deleteCourse(id) {
            if (!confirm('确定删除该课程吗？')) return;
            await fetch(`${API_BASE}/courses/${id}`, { method: 'DELETE' });
            loadCourses();
        }

        function filterCoursesByTopic() {
            // Filter is applied on next reload - just trigger reload
            loadCourses();
        }
    </script>
</body>

</html>









